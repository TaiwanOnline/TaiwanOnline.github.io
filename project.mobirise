              "@media (max-width: 992px)": {
                "padding": "24px"
              },
              ".mbr-section-title": {
                "margin-bottom": "16px",
                "@media (max-width: 992px)": {
                  "text-align": "left"
                }
              },
              ".mbr-text": {
                "margin-bottom": "0",
                "@media (max-width: 992px)": {
                  "text-align": "left"
                }
              },
              ".mbr-section-btn": {
                "margin-top": "32px",
                "@media (max-width: 992px)": {
                  "text-align": "left",
                  "margin-top": "24px"
                }
              }
            },
            ".items": {
              "border-left": "1px solid @border",
              "& when (@reverseContent)": {
                "border-left": "none",
                "border-right": "1px solid @border"
              },
              "@media (max-width: 992px)": {
                "border-top": "1px solid @border"
              },
              ".item": {
                "padding": "32px",
                "border-bottom": "1px solid @border",
                "@media (max-width: 992px)": {
                  "padding": "24px"
                },
                "&:last-child": {
                  "border": "none"
                },
                ".item-wrapper": {
                  ".card-box": {
                    ".title-wrapper": {
                      "margin-bottom": "8px",
                      ".title-wrap": {
                        "display": "inline-flex",
                        ".card-title": {
                          "margin-bottom": "0"
                        },
                        ".card-number": {
                          "margin": "0 0 0 8px",
                          "min-width": "22px"
                        }
                      }
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#F9F6E0"
            },
            ".mbr-text": {

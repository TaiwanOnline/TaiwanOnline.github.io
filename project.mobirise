        {
          "_name": "content7",
          "_sourceTheme": "dentalm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content7 dentalm5\" group=\"Content\"\r\n         mbr-class=\"{'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\">\r\n\r\n    <mbr-parameters>\r\n        <header>Size</header>\r\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\r\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\r\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\"\r\n               condition=\"fullScreen == false\">\r\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\"\r\n               condition=\"fullScreen == false\">\r\n        <header>Show/Hide</header>\r\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\r\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\r\n        <header>Background</header>\r\n        <fieldset type=\"background\" name=\"bg\" parallax>\r\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/dentalm5/components/_images/background1.jpg\" parallax>\r\n            <input type=\"color\" title=\"Color\" value=\"#F2C4B3\" selected>\r\n        </fieldset>\r\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\r\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/dentalm5/components/_images/background1.jpg\" name=\"fallBackImage\"\r\n               condition=\"bg.type === 'video'\">\r\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\r\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\"\r\n               condition=\"overlay && bg.type !== 'color'\">\r\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\"\r\n               condition=\"overlay && bg.type !== 'color'\">\r\n    </mbr-parameters>\r\n\r\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\r\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\"\r\n         mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\r\n    </div>\r\n\r\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\r\n        <div class=\"row\">\r\n            <div class=\"col-12 col-lg-8\">\r\n                <div class=\"title-wrapper\">\r\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\"\r\n                        mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\r\n                        Main Treatment Techniques in Dentistry\r\n                    </h2>\r\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\"\r\n                       mbr-theme-style=\"display-7\" mbr-if=\"showText\">\r\n                        There are several main treatment techniques used in dentistry to address a wide range of dental\r\n                        issues. Here are some of the most common techniques:\r\n                    </p>\r\n                    <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\"\r\n                        data-multiline\r\n                        mbr-article>\r\n                        <li class=\"item-wrap\">Fillings</li>\r\n                        <li class=\"item-wrap\">Root Canal Therapy</li>\r\n                        <li class=\"item-wrap\">Crowns</li>\r\n                        <li class=\"item-wrap\">Bridges</li>\r\n                        <li class=\"item-wrap\">Implants</li>\r\n                        <li class=\"item-wrap\">Orthodontics</li>\r\n                    </ul>\r\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\"\r\n                       mbr-theme-style=\"display-7\" mbr-if=\"showText\">\r\n                        These are just a few of the many treatment techniques used in dentistry. Your dentist can\r\n                        provide more information about which treatments are appropriate for your individual needs.\r\n                    </p>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {

        {
          "_name": "content8",
          "_sourceTheme": "leaderm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content8\" group=\"Content\" mbr-class=\"{'mbr-fullscreen': fullScreen,\n                    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\"\n               condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\"\n               condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Phone\" name=\"showPhone\" checked>\n        <input type=\"range\" inline title=\"Links\" name=\"links\" min=\"0\" max=\"6\" step=\"1\" value=\"3\">\n        <input type=\"color\" title=\"Container\" name=\"container\" value=\"#ffffff\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#f1f1f2\" selected>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/leaderm5/components/_images/background1.jpg\" parallax>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/leaderm5/components/_images/background1.jpg\" name=\"fallBackImage\"\n               condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\"\n               condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\"\n               condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\"\n         mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div mbr-class=\"{'container': !fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-6\">\n                <div class=\"title-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\"\n                        data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\"\n                        mbr-if=\"showTitle\">\n                        <b>LOCATE IN NEW-YORK AND ALWAYS BY ADDRESS</b>\n                    </h2>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\"\n                       data-app-selector=\".mbr-text\">\n                        Lorem ipsum dolor sit amet, consectetur adipisicing elit. Ad at commodi corporis, deleniti\n                        fugiat illum in inventore iste iusto libero minima quisquam quod rem sed sint? Consequuntur\n                        eaque ipsum perferendis.\n                    </p>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-6\">\n                <div class=\"phone-wrapper\">\n                    <h3 class=\"mbr-section-subtitle mbr-fonts-style\"\n                        data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\"\n                        mbr-if=\"showSubtitle\">\n                        <b>OUR PHONE</b>\n                    </h3>\n                    <p class=\"mbr-phone mbr-fonts-style\"\n                       data-app-selector=\".mbr-phone\" mbr-theme-style=\"display-5\"\n                       mbr-if=\"showPhone\">\n                        <b>987-654-32-10</b>\n                    </p>\n                </div>\n                <div class=\"links-wrapper\">\n                    <h3 class=\"mbr-section-subtitle mbr-fonts-style\"\n                        data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\"\n                        mbr-if=\"showSubtitle\">\n                        <b>OUR PHONE</b>\n                    </h3>\n                    <a href=\"#\">\n                        <p class=\"mbr-link mbr-fonts-style\" data-app-selector=\".mbr-link\"\n                                   mbr-theme-style=\"display-5\"><b>LINKEDIN</b>\n                        </p>\n                    </a>\n                    <a href=\"#\" mbr-if=\"links > 1\">\n                        <p class=\"mbr-link mbr-fonts-style\" data-app-selector=\".mbr-link\"\n                                  mbr-theme-style=\"display-5\" ><b>INSTAGRAM</b>\n                        </p>\n                    </a>\n                    <a href=\"#\" mbr-if=\"links > 2\">\n                        <p class=\"mbr-link mbr-fonts-style\" data-app-selector=\".mbr-link\" mbr-theme-style=\"display-5\">\n                            <b>FACEBOOK</b>\n                        </p>\n                    </a>\n                    <a href=\"#\" mbr-if=\"links > 3\">\n                        <p class=\"mbr-link mbr-fonts-style\" data-app-selector=\".mbr-link\" mbr-theme-style=\"display-5\">\n                            <b>TELEGRAM</b>\n                        </p>\n                    </a>\n                    <a href=\"#\" mbr-if=\"links > 4\">\n                        <p class=\"mbr-link mbr-fonts-style\" data-app-selector=\".mbr-link\" mbr-theme-style=\"display-5\">\n                            <b>TWITTER</b>\n                    </p>\n                    </a>\n                    <a href=\"#\" mbr-if=\"links > 5\">\n                        <p class=\"mbr-link mbr-fonts-style\" data-app-selector=\".mbr-link\" mbr-theme-style=\"display-5\">\n                            <b>INSTAGRAM</b>\n                        </p>\n                    </a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {

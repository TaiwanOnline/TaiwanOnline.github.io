          "_sourceTheme": "personam4",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content10 personam4_content10\" group=\"Content\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\">\n\n\t<mbr-parameters>\n\t\t\n\t\t<header>Size</header>\n\t\t<input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n\t\t<input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"15\" step=\"1\" value=\"4\" condition=\"fullScreen == false\">\n\t\t<input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"15\" step=\"1\" value=\"4\" condition=\"fullScreen == false\">\n\t\t<header>Show / Hide</header>\n\t\t<input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n\t\t<input type=\"checkbox\" title=\"Sub Title\" name=\"showSubTitle\" checked>\n\t\t<input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n\t\t<input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n\t\t<header>Background</header>\n\t\t<fieldset type=\"background\" name=\"bg\" parallax>\n\t\t\t<input type=\"image\" title=\"Image\" value=\"../_images/background5.jpg\" selected>\n\t\t\t<input type=\"color\" title=\"Color\" value=\"#3d626c\">\n\t\t\t<input type=\"video\" title=\"Video\" value=\"https://www.youtube.com/watch?v=36YgDDJ7XSc\">\n\t\t</fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n\t\t<input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n\t\t<input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n\t\t<input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.3\" condition=\"overlay && bg.type !== 'color'\">\n\t\t\n\t</mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n\n\t<div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n\t<div class=\"container align-left\">\n\t\t<div class=\"row\">\n\t\t\t<div class=\"col-md-7 col-lg-5\">\n\t\t\t\t<h1 class=\"mbr-section-title mbr-semibold pb-2 mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n\t\t\t\t\tHi I’m Josh Norton\n\t\t\t\t</h1>\n\t\t\t\t<p class=\"mbr-text pb-3 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showSubTitle\" data-app-selector=\".mbr-text, .mbr-section-btn\">A multi-disciplinary designer with more than 10\n\t\t\t\t\tyears of experience in design, an avid reader.</p>\n\n\t\t\t\t<div class=\"pt-3\" mbr-if=\"showText || showButtons\">\n\t\t\t\t\t<h3 class=\"mbr-section-subtitle align-left mbr-light pb-2 mbr-fonts-style\" mbr-theme-style=\"display-5\">\n\t\t\t\t\t\tAbout</h3>\n\t\t\t\t\t<p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">A multi-disciplinary designer with more than 10\n\t\t\t\t\t\tyears of experience in design, an avid reader, dog owner</p>\n\t\t\t\t\t<div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-md btn-primary-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">PORTFOLIO</a></div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"pt-5\">\n\t\t\t\t\t<h3 class=\"mbr-section-subtitle align-left mbr-light pb-2 mbr-fonts-style\" mbr-theme-style=\"display-5\">\n\t\t\t\t\t\tAbout</h3>\n\t\t\t\t\t<p class=\"mbr-text pb-3 mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-text, .mbr-section-btn\">The Design Observer\n\t\t\t\t\t\t<br>MBAM / Livre Chihuly\n\t\t\t\t\t\t<br>The Type Directors Club 60\n\t\t\t\t\t\t<br>Naturiste / Identité\n\t\t\t\t\t\t<br>Arche de Québec\n\t\t\t\t\t\t<br></p>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"pt-4\">\n\t\t\t\t\t<h3 class=\"mbr-section-subtitle align-left mbr-light pb-2 mbr-fonts-style\" mbr-theme-style=\"display-5\">\n\t\t\t\t\t\tAwards</h3>\n\t\t\t\t\t<p class=\"mbr-text pb-3 mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-text, .mbr-section-btn\">The Design Observer Group – 50 books\n\t\t\t\t\t\t<br>MBAM / Livre Chihuly\n\t\t\t\t\t\t<br>The Type Directors Club 60\n\t\t\t\t\t\t<br>Naturiste / Identité\n\t\t\t\t\t\t<br>Arche de Québec / Linge à vaisselle\n\t\t\t\t\t\t<br></p>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"pt-4\">\n\t\t\t\t\t<h3 class=\"mbr-section-subtitle align-left mbr-light pb-2 mbr-fonts-style\" mbr-theme-style=\"display-5\">Contact&nbsp;</h3>\n\t\t\t\t\t<p class=\"mbr-text pb-3 mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-text, .mbr-section-btn\">info@site.com&nbsp;<br>Behance\n\t\t\t\t\t\t<br>Instagram\n\t\t\t\t\t\t<br>Twitter</p>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</section>",
          "_cid": "u6xiNmoMBg",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "content10-b5"
        }
      ]
    },
    "blog.html": {
      "settings": {
        "title": "Blog",
        "order": "2"
      },
      "components": [
        {
          "_name": "amenu1",
          "_sourceTheme": "spiritm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu menu1 spiritm5\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" name=\"fullWidth\" title=\"Full Width\" checked>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Logo\" name=\"showLogo\">\n        <input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"3\" max=\"10\" step=\"0.1\" value=\"8\" condition=\"showLogo\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <input type=\"checkbox\" title=\"Menu Items\" name=\"showItems\" checked>\n        <input type=\"checkbox\" title=\"Icons\" name=\"showIcons\">\n        <select title=\"Amount\" name=\"iconsAmount\" condition=\"showIcons\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\" selected>3</option>\n            <option value=\"4\">4</option>\n        </select>\n        <input type=\"color\" title=\"Icons Color\" name=\"iconsColor\" value=\"#FFFFFF\" condition=\"showIcons\">\n        <input type=\"checkbox\" title=\"Button\" name=\"showButtons\">\n        <header>Styles</header>\n        <input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n        <input type=\"checkbox\" title=\"Transparent\" name=\"transparent\" checked>\n        <input type=\"range\" title=\"Opacity\" name=\"opacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0\" condition=\"transparent\">\n        <input type=\"color\" title=\"Color\" name=\"menuBgColor\" value=\"#1a2229\">\n        <input type=\"color\" title=\"Hamburger\" name=\"hamburgerColor\" value=\"#FFFFFF\">\n        <input type=\"color\" title=\"Hamburger Bg\" name=\"hamburgerBgColor\" value=\"#b84358\">\n    </mbr-parameters>\n\n    <nav class=\"navbar navbar-dropdown collapsed\" mbr-class=\"{'navbar-fixed-top':sticky}\">\n        <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n            <div class=\"toggler-container header-item\">\n                <button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\" mbr-if=\"showItems || showIcons || showButtons\">\n                    <div class=\"hamburger-bg\"></div>\n                    <div class=\"hamburger\">\n                        <span></span>\n                        <span></span>\n                        <span></span>\n                        <span></span>\n                    </div>\n                </button>\n            </div>\n            <div class=\"navbar-brand header-item\">\n                <span mbr-if=\"showLogo\" class=\"navbar-logo\">\n                    <a href=\"https://mobiri.se\">\n                        <img src=\"@PROJECT_PATH@/assets/images/logo.png\" alt=\"Mobirise Website Builder\" mbr-style=\"{'height': logoSize + 'rem'}\">\n                    </a>\n                </span>\n            </div>\n            <div class=\"header-text-container header-item\">\n                <p class=\"mbr-text mbr-fonts-style mb-0 align-right\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                    WELCOME TO SPIRITM5\n                </p>\n            </div>\n\n            <div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\" mbr-if=\"showItems || showIcons || showButtons\">\n                <ul mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-4\" mbr-if=\"showItems\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish && !showBrand && !showLogo}\"><li class=\"nav-item\"><a class=\"nav-link link text-info\" href=\"https://mobiri.se\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">首頁</a>\n                    </li>\n                    <li class=\"nav-item\"><a class=\"nav-link link text-info\" href=\"https://mobiri.se\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">\n                        PRIVATE CASKS\n                    </a>\n                    </li>\n                    <li class=\"nav-item\"><a class=\"nav-link link text-info\" href=\"https://mobiri.se\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">\n                        EXPERIENCES\n                    </a>\n                    </li>\n                    <li class=\"nav-item\"><a class=\"nav-link link text-info\" href=\"https://mobiri.se\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">\n                        EXPERIMENTATIONS\n                    </a>\n                    </li>\n                    <li class=\"nav-item\"><a class=\"nav-link link text-info\" href=\"https://mobiri.se\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">\n                        CONTACT\n                    </a>\n                    </li></ul>\n                <div class=\"icons-menu\" mbr-if=\"showIcons\">\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\">\n                        <span mbr-icon class=\"p-3 mbr-iconfont socicon-facebook socicon\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 1\">\n                        <span mbr-icon class=\"p-3 mbr-iconfont socicon-twitter socicon\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 2\">\n                        <span mbr-icon class=\"p-3 mbr-iconfont socicon-instagram socicon\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 3\">\n                        <span mbr-icon class=\"p-3 mbr-iconfont socicon-linkedin socicon\"></span>\n                    </a>\n                </div>\n                <div mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-7\" class=\"navbar-buttons mbr-section-btn\">\n                    <a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                        READ MORE</a>\n                </div>\n            </div>\n        </div>\n    </nav>\n</section>",
          "_styles": {
            "& when not (@sticky)": {
              ".navbar-dropdown": {
                "position": "relative !important"
              },
              "& when (@transparent)": {
                ".navbar-dropdown": {
                  "position": "absolute !important"
                }
              }
            },
            "& when (@sticky)": {
              "z-index": "1000",
              "width": "100%",
              "& when not (@transparent)": {
                "position": "relative",
                "min-height": "60px"
              },
              "nav.navbar": {
                "position": "fixed"
              }
            },
            ".dropdown-item:before": {
              "font-family": "Moririse2 !important",
              "content": "\"\\e966\"",
              "display": "inline-block",
              "width": "0",
              "position": "absolute",
              "left": "1rem",
              "top": "0.5rem",
              "margin-right": "0.5rem",
              "line-height": "1",
              "font-size": "inherit",
              "vertical-align": "middle",
              "text-align": "center",
              "overflow": "hidden",
              "transform": "scale(0, 1)",
              "transition": "all 0.25s ease-in-out"
            },
            ".dropdown-menu": {
              "padding": "0",
              "border-radius": "4px",
              "box-shadow": "0 1px 3px 0 rgba(0, 0, 0, 0.1)"
            },
            ".dropdown-item": {
              "border-bottom": "1px solid rgba(255, 255, 255, 0.1)",
              "transition": ".4s all !important",
              "&:hover, &:focus": {
                "background": "rgba(red(@infoColor), green(@infoColor), blue(@infoColor), 0.5) !important",
                "color": "white !important"
              },
              "&:hover span": {
                "color": "white"
              },
              "&:first-child": {
                "border-top-left-radius": "4px",
                "border-top-right-radius": "4px"
              },
              "&:last-child": {
                "border-bottom": "none",
                "border-bottom-left-radius": "4px",
                "border-bottom-right-radius": "4px"
              }
            },
            ".nav-dropdown .link": {
              "padding": "0 0.3em !important",
              "margin": "0.667em 1em !important",
              "text-align": "center"
            },
            ".nav-dropdown .link.dropdown-toggle::after": {
              "margin-left": "0.5rem",
              "margin-top": "0.2rem"
            },
            ".nav-link": {
              "position": "relative"
            },
            ".container": {
              "display": "flex",
              "margin": "auto",
              "max-width": "1600px"
            },
            ".iconfont-wrapper": {
              "color": "@iconsColor !important",
              "font-size": "1.5rem",
              "padding-right": "0 !important",
              ".mbr-iconfont": {
                "transition": ".4s all"
              },
              "&:hover": {
                ".mbr-iconfont": {
                  "color": "@primaryColor"
                }
              }
            },
            ".navbar-caption": {},
            ".navbar-nav": {},
            ".dropdown-menu, .navbar.opened": {
              "background": "@menuBgColor !important"
            },
            ".nav-item:focus, .nav-link:focus": {
              "outline": "none"
            },
            ".dropdown .dropdown-menu .dropdown-item": {
              "width": "auto",
              "transition": "all 0.25s ease-in-out",
              "&::after": {
                "right": "0.5rem"
              },
              ".mbr-iconfont": {
                "margin-right": "0.5rem",
                "vertical-align": "sub",
                "&:before": {
                  "display": "inline-block",
                  "transform": "scale(1, 1)",
                  "transition": "all 0.25s ease-in-out"
                }
              }
            },
            ".collapsed": {
              ".dropdown-menu .dropdown-item:before": {
                "display": "none"
              },
              ".dropdown .dropdown-menu .dropdown-item": {
                "padding": "0.235em 1.5em 0.235em 1.5em !important",
                "transition": "none",
                "margin": "0 !important"
              }
            },
            ".navbar": {
              "min-height": "70px",
              "transition": "all 0.3s",
              "border-bottom": "1px solid transparent",
              "& when not (@transparent)": {
                "box-shadow": "0 1px 3px 0 rgba(0, 0, 0, 0.1)",
                "background": "@menuBgColor"
              },
              "& when (@transparent)": {
                "background": "rgba(red(@menuBgColor), green(@menuBgColor), blue(@menuBgColor), @opacity)"
              },
              "&.opened": {
                "transition": "all 0.3s"
              },
              ".dropdown-item": {
                "padding": "0.5rem 1.8rem"
              },
              ".navbar-logo img": {
                "width": "auto"
              },
              ".navbar-collapse": {
                "justify-content": "flex-end",
                "z-index": "1"
              },
              "&.collapsed": {
                "justify-content": "center",
                ".nav-item .nav-link::before": {
                  "display": "none"
                },
                "&.opened": {
                  ".dropdown-menu": {
                    "top": "0"
                  }
                },
                ".dropdown-menu": {
                  ".dropdown-submenu": {
                    "left": "0 !important"
                  },
                  ".dropdown-item:after": {
                    "right": "auto"
                  },
                  ".dropdown-toggle[data-toggle=\"dropdown-submenu\"]:after": {
                    "margin-left": "0.5rem",
                    "margin-top": "0.2rem",
                    "border-top": "0.35em solid",
                    "border-right": "0.35em solid transparent",
                    "border-left": "0.35em solid transparent",
                    "border-bottom": "0",
                    "top": "41%"
                  }
                },
                "ul.navbar-nav": {
                  "li": {
                    "margin": "auto"
                  }
                },
                ".dropdown-menu .dropdown-item": {
                  "padding": "0.25rem 1.5rem",
                  "text-align": "center"
                },
                ".icons-menu": {
                  "padding-left": "0",
                  "padding-right": "0",
                  "padding-top": "0.5rem",
                  "padding-bottom": "0.5rem"
                }
              },
              "@media (max-width: 991px)": {
                ".nav-item .nav-link::before": {
                  "display": "none"
                },
                "&.opened": {
                  ".dropdown-menu": {
                    "top": "0"
                  }
                },
                ".dropdown-menu": {
                  ".dropdown-submenu": {
                    "left": "0 !important"
                  },
                  ".dropdown-item:after": {
                    "right": "auto"
                  },
                  ".dropdown-toggle[data-toggle=\"dropdown-submenu\"]:after": {
                    "margin-left": "0.5rem",
                    "margin-top": "0.2rem",
                    "border-top": "0.35em solid",
                    "border-right": "0.35em solid transparent",
                    "border-left": "0.35em solid transparent",
                    "border-bottom": "0",
                    "top": "40%"
                  }
                },
                "ul.navbar-nav": {
                  "li": {
                    "margin": "auto"
                  }
                },
                ".dropdown-menu .dropdown-item": {
                  "padding": "0.25rem 1.5rem !important",
                  "text-align": "center"
                },
                ".navbar-brand": {
                  "flex-shrink": "initial",
                  "flex-basis": "auto",
                  "word-break": "break-word"
                },
                ".navbar-toggler": {
                  "flex-basis": "auto"
                },
                ".icons-menu": {
                  "padding-left": "0",
                  "padding-top": "0.5rem",
                  "padding-bottom": "0.5rem"
                }
              },
              "padding": "0 !important"
            },
            ".navbar-brand": {
              "min-height": "70px",
              "flex-shrink": "0",
              "align-items": "flex-start",
              "margin-right": "0",
              "padding": "0 !important",
              "transition": "all 0.3s",
              "word-break": "break-word",
              "z-index": "1",
              ".navbar-caption": {
                "line-height": "inherit !important"
              },
              ".navbar-logo a": {
                "outline": "none"
              },
              "display": "flex",
              "justify-content": "center"
            },
            ".dropdown-item.active, .dropdown-item:active": {
              "background-color": "transparent"
            },
            ".navbar-expand-lg .navbar-nav .nav-link": {
              "padding": "0"
            },
            ".nav-dropdown .link.dropdown-toggle": {
              "margin-right": "1.667em",
              "&[aria-expanded=\"true\"]": {
                "margin-right": "0",
                "padding": "0.667em 1.667em"
              }
            },
            ".navbar.navbar-expand-lg .dropdown": {
              ".dropdown-menu": {
                "background": "@menuBgColor",
                ".dropdown-submenu": {
                  "margin": "0",
                  "left": "100%"
                }
              }
            },
            ".navbar .dropdown.open > .dropdown-menu": {
              "display": "block"
            },
            "ul.navbar-nav": {
              "flex-wrap": "wrap"
            },
            ".navbar-buttons": {
              "text-align": "center",
              "min-width": "170px"
            },
            "button.navbar-toggler": {
              "outline": "none",
              "width": "26px",
              "height": "20px",
              "cursor": "pointer",
              "transition": "all 0.2s",
              "position": "relative",
              "align-self": "center",
              ".hamburger span": {
                "position": "absolute",
                "right": "0",
                "width": "25px",
                "height": "2px",
                "border-right": "5px",
                "background-color": "@hamburgerColor",
                "&:nth-child(1)": {
                  "top": "0",
                  "transition": "all 0.2s"
                },
                "&:nth-child(2)": {
                  "top": "8px",
                  "transition": "all 0.15s"
                },
                "&:nth-child(3)": {
                  "top": "8px",
                  "transition": "all 0.15s"
                },
                "&:nth-child(4)": {
                  "top": "16px",
                  "transition": "all 0.2s"
                }
              }
            },
            "nav.opened .hamburger span": {
              "&:nth-child(1)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.2s"
              },
              "&:nth-child(2)": {
                "transform": "rotate(45deg)",
                "transition": "all 0.25s"
              },
              "&:nth-child(3)": {
                "transform": "rotate(-45deg)",
                "transition": "all 0.25s"
              },
              "&:nth-child(4)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.2s"
              }
            },
            ".navbar-dropdown": {
              "padding": "0 1rem",
              "& when (@sticky)": {
                "position": "fixed"
              }
            },
            "a.nav-link": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center"
            },
            ".icons-menu": {
              "flex-wrap": "nowrap",
              "display": "flex",
              "justify-content": "center",
              "padding-left": "1rem",
              "padding-right": "1rem",
              "padding-top": "0.3rem",
              "text-align": "center"
            },
            "@media screen and (~'-ms-high-contrast: active'), (~'-ms-high-contrast: none')": {
              ".navbar": {
                "height": "70px",
                "&.opened": {
                  "height": "auto"
                }
              },
              ".nav-item .nav-link:hover::before": {
                "width": "175%",
                "max-width": "calc(100% ~\"+\" 2rem)",
                "left": "-1rem"
              }
            },
            ".header-item": {
              "width": "(100% / 3)",
              "padding": "10px 0"
            },
            ".navbar-toggler": {
              "margin-left": "10px"
            },
            ".hamburger-bg": {
              "position": "absolute",
              "top": "50%",
              "left": "50%",
              "width": "~\"calc(100% + 20px)\"",
              "aspect-ratio": "(1 / 1)",
              "transform": "translate(-50%, -50%)",
              "border-radius": "50%",
              "background-color": "@hamburgerBgColor"
            },
            ".navbar-logo": {
              "margin-right": "0 !important"
            },
            ".mbr-text": {
              "width": "100%",
              "color": "#BF9341",
              "@media (max-width: 575px)": {
                "display": "none"
              }
            },
            ".navbar-collapse": {
              "padding-top": "40px !important"
            },
            ".mbr-section-btn": {
              "margin-top": "10px",
              "@media (max-width: 575px)": {
                "display": "flex",
                "flex-wrap": "wrap"
              }
            }
          },
          "_cid": "u6l69dlEUY",
          "_anchor": "amenu1-7j",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "_name": "news2",
          "_sourceTheme": "bistrom5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"news2 bistro_news2\" group=\"News\" mbr-class=\"{'mbr-parallax-background':bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"4\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"4\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <header>Card</header>\n        <input type=\"range\" inline title=\"Width\" name=\"cardsWidth\" min=\"4\" max=\"12\" step=\"1\" value=\"9\">\n        <input type=\"checkbox\" title=\"Info\" name=\"showCardInfo\" checked>\n        <input type=\"checkbox\" title=\"Title\" name=\"cardTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"cardText\" checked>\n        <input type=\"checkbox\" title=\"Link\" name=\"showButtons\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/bistrom5/components/_images/background.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Second Color\" name=\"bgColor2\" condition=\"bg.type == 'color'\">\n        <input type=\"color\" title=\"Color\" value=\"#fef2f2\" name=\"twoBgColor\" condition=\"bgColor2 && bg.type == 'color'\">\n        <input type=\"range\" name=\"bgHeight\" title=\"Proportion\" min=\"1\" max=\"10\" step=\"1\" value=\"6\" condition=\"bgColor2 && bg.type == 'color'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.9\" condition=\"overlay && bg.type !== 'color'\">\n        <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n    <div class=\"two_background\"></div>\n    \n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-if=\"showTitle || showText\">\n            <div class=\"col-12 col-lg-12\">\n                <div class=\"head_title\">\n                    <h3 class=\"mbr-section-title mbr-fonts-style\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\">READ OUR BLOG</h3>\n                    <p class=\"mbr-text mb-0 mbr-fonts-style\" mbr-if=\"showText\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-4\">Lorem ipsum dolor sit amet, consectetur adipisicing elit. Sit ex voluptatem voluptas aut quod, autem obcaecati molestiae optio consequuntur.</p>\n                </div>\n            </div>\n        </div>\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-md-10 col-lg-{{cardsWidth}}\">\n                <div class=\"card_box\">\n                    <div class=\"item-img\">\n                        <img src=\"@PROJECT_PATH@/assets/images/bistro10.jpg\" data-slide-to=\"0\" data-bs-slide-to=\"0\" alt>\n                    </div>\n                    <div class=\"card_info\" mbr-if=\"showCardInfo\">\n                        <p class=\"card_date mb-0 mbr-fonts-style\" data-app-selector=\".card_date\" mbr-theme-style=\"display-4\">April 13, 2025 / Cocktails</p>\n                    </div>\n                    <h3 class=\"card_title mbr-fonts-style\" mbr-if=\"cardTitle\" data-app-selector=\".card_title\" mbr-theme-style=\"display-2\">Delicious desserts with your own hands</h3>\n                    <p class=\"card_text mbr-fonts-style\" mbr-if=\"cardText\" data-app-selector=\".card_text, .linkBtn\" mbr-theme-style=\"display-4\">Lorem ipsum dolor sit amet, consectetur adipisicing elit. Dolorum accusantium, ipsam sunt corporis veritatis debitis. Tempora blanditiis quisquam porro debitis sit praesentium est voluptates excepturi eos quibusdam. Minus dolore, sapiente.</p>\n                    <p class=\"linkBtn mb-0 mbr-fonts-style\" data-app-selector=\".linkBtn\" mbr-theme-style=\"display-4\" mbr-if=\"showButtons\"><a href=\"index.html\" class=\"text-secondary\">READ MORE</a></p>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "position": "relative",
            "overflow": "hidden",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)",
              "& when (@overlay)": {
                ".mbr-overlay": {
                  "background": "@overlayColor",
                  "opacity": "@overlayOpacity"
                }
              }
            },
            ".mbr-section-title": {
              "margin-bottom": "18px",
              "color": "#202020"
            },
            ".head_title": {
              "margin": "25px 0 58px",
              "text-align": "center"
            },
            "& when (@bgColor2) and (@bg-type = 'color')": {
              ".two_background": {
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "(@bgHeight * 10%)",
                "background-color": "@twoBgColor",
                "z-index": "0"
              }
            },
            ".card_box": {
              "margin-bottom": "65px",
              "height": "100%",
              "display": "flex",
              "flex-flow": "column nowrap"
            },
            ".card_info": {
              "margin-bottom": "12px"
            },
            ".card_date": {
              "color": "#555555"
            },
            ".card_title": {
              "line-height": "1.1em",
              "margin-bottom": "18px",
              "color": "#202020"
            },
            ".card_text": {
              "margin-top": "4px"
            },
            ".item-img": {
              "margin-bottom": "30px",
              "img": {
                "width": "100%",
                "object-fit": "cover",
                "display": "block",
                "max-height": "450px"
              }
            },
            ".linkBtn a": {
              "position": "relative",
              "display": "inline-block",
              "padding": "1px 7px",
              "vertical-align": "middle",
              "overflow": "hidden",
              "line-height": "2em",
              "font-weight": "600",
              "text-decoration": "none",
              "letter-spacing": ".2em",
              "&:after, &:before": {
                "content": "''",
                "display": "block",
                "width": "100%",
                "height": "1px",
                "position": "absolute",
                "bottom": "0",
                "background-color": "currentColor",
                "transition": "transform 0.4s cubic-bezier(0.31, 0.29, 0.05, 0.96)"
              },
              "&:before": {
                "left": "0"
              },
              "&:after": {
                "left": "-100%",
                "transition-delay": ".3s"
              },
              "&:hover": {
                "&:before, &:after": {
                  "transform": "translateX(100%)"
                }
              }
            }
          },
          "_cid": "u6l4flcyBM",
          "_anchor": "news2-7g",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0 30px",
                "@media (max-width: 768px)": {
                  "padding": "0 20px"
                }
              }
            },
            ".container": {
              "@media (max-width: 992px)": {
                "padding": "0 20px"
              }
            },
            ".row": {
              "justify-content": "center",
              "padding": "60px 0",
              "@media (max-width: 992px)": {
                "padding": "46px 0"
              }
            },
            ".mbr-desc": {
              "margin-bottom": "60px",
              "@media (max-width: 992px)": {
                "margin-bottom": "32px"
              },
              "color": "#000000"
            },
            ".content-wrapper": {
              "margin-right": "100px",
              "& when (@reverseContent)": {
                "margin-right": "0",
                "margin-left": "100px",
                "@media (max-width: 992px)": {
                  "margin-left": "0"
                }
              },
              "@media (max-width: 992px)": {
                "margin-right": "0"
              },
              ".mbr-section-title": {
                "margin-bottom": "60px",
                "@media (max-width: 992px)": {
                  "margin-bottom": "46px"
                }
              },
              ".mbr-text": {
                "@media (max-width: 992px)": {
                  "margin-bottom": "60px"
                }
              }
            },
            ".tabs-wrap": {
              "margin-bottom": "40px",
              "margin-left": "60px",
              "& when (@reverseContent)": {
                "margin-left": "0",
                "margin-right": "60px",
                "@media (max-width: 992px)": {
                  "margin-right": "0"
                }
              },
              "@media (max-width: 992px)": {
                "margin-left": "0"
              },
              ".nav.nav-tabs": {
                "display": "flex",
                "flex-wrap": "wrap",
                "border": "none",
                "justify-content": "space-between",
                "margin-bottom": "32px",
                ".nav-item": {
                  "padding": "0",
                  "border": "none",
                  "border-radius": "0",
                  "margin": "0 5px 10px",
                  "transition": "all 0.3s ease-in-out",
                  "&:last-child": {
                    "margin-right": "0"
                  },
                  ".nav-link": {
                    "display": "flex",
                    "align-items": "center",
                    "justify-content": "center",
                    "margin-bottom": "0",
                    "border": "none",
                    "color": "@tabs",
                    "transition": "all 0.3s ease-in-out",
                    "opacity": ".5",
                    "text-align": "center"
                  },
                  ".nav-link.active": {
                    "opacity": "1"
                  }
                }
              },
              ".tab-content": {
                ".tab-pane": {
                  ".image-wrapper": {
                    "img": {
                      "height": "350px",
                      "border-radius": "20px !important",
                      "object-fit": "cover"
                    }
                  }
                }
              },
              "text-align": "right"
            },
            ".mbr-section-title": {
              "color": "#000000"
            },
            ".mbr-text": {
              "color": "#000000"
            },
            ".card-name": {
              "color": "#000000"
            },
            ".card-role": {
              "color": "#000000",
              "text-align": "center"
            },
            ".list, .tags-wrapper": {
              "color": "#000000",
              "text-align": "center"
            },
            ".card-name, .mbr-section-btn": {
              "text-align": "center"
            }
          },
          "_name": "tabs02",
          "_sourceTheme": "immersem5",
          "_customHTML": "<section data-bs-version=\"5.1\"\r\n        class=\"tabs02 immersem5\"\r\n        group=\"List\"\r\n        plugins=\"mbr-tabs\"\r\n        mbr-class=\"{\r\n\r\n    'mbr-fullscreen': fullScreen,\r\n    'mbr-parallax-background': bg.parallax}\"\r\n>\r\n    <mbr-parameters>\r\n        <header>Size</header>\r\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\"/>\r\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked/>\r\n        <input\r\n                type=\"range\"\r\n                inline\r\n                title=\"Top\"\r\n                name=\"paddingTop\"\r\n                min=\"0\"\r\n                max=\"12\"\r\n                step=\"1\"\r\n                value=\"1\"\r\n                condition=\"fullScreen == false\"\r\n        />\r\n        <input\r\n                type=\"range\"\r\n                inline\r\n                title=\"Bottom\"\r\n                name=\"paddingBottom\"\r\n                min=\"0\"\r\n                max=\"12\"\r\n                step=\"1\"\r\n                value=\"1\"\r\n                condition=\"fullScreen == false\"\r\n        />\r\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\"/>\r\n        <header>Show/Hide</header>\r\n        <input type=\"checkbox\" title=\"Description\" name=\"showDesc\" checked/>\r\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked/>\r\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked/>\r\n        <header>Tabs</header>\r\n        <select title=\"Count\" name=\"bootstrapTabs\">\r\n            <option value=\"1\">1</option>\r\n            <option value=\"2\">2</option>\r\n            <option value=\"3\">3</option>\r\n            <option value=\"4\" selected>4</option>\r\n        </select>\r\n        <input type=\"color\" title=\"Tabs Color\" value=\"#000000\" name=\"tabs\" selected/>\r\n        <header>Background</header>\r\n        <fieldset type=\"background\" name=\"bg\" parallax>\r\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/immersem5/components/_images/background1.jpg\"/>\r\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected/>\r\n        </fieldset>\r\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\r\n        <input\r\n                type=\"image\"\r\n                title=\"Fallback Image\"\r\n                value=\"@ADDONS_PATH@/immersem5/components/_images/background1.jpg\"\r\n                name=\"fallBackImage\"\r\n                condition=\"bg.type === 'video'\"\r\n        />\r\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\"/>\r\n        <input\r\n                type=\"color\"\r\n                title=\"Overlay Color\"\r\n                name=\"overlayColor\"\r\n                value=\"#ffffff\"\r\n                condition=\"overlay && bg.type !== 'color'\"\r\n        />\r\n        <input\r\n                type=\"range\"\r\n                inline\r\n                title=\"Opacity\"\r\n                name=\"overlayOpacity\"\r\n                min=\"0\"\r\n                max=\"1\"\r\n                step=\"0.1\"\r\n                value=\"0.8\"\r\n                condition=\"overlay && bg.type !== 'color'\"\r\n        />\r\n    </mbr-parameters>\r\n\r\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\r\n    <div\r\n            class=\"mbr-overlay\"\r\n            mbr-if=\"overlay && bg.type !== 'color'\"\r\n            opacity=\"{{overlayOpacity}}\"\r\n            bg-color=\"{{overlayColor}}\"\r\n    ></div>\r\n\r\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\r\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\r\n            <div class=\"col-12 col-lg-10\">\r\n                <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showDesc\"\r\n                   data-app-selector=\".mbr-desc\">\r\n                    Classrooms\r\n                </p>\r\n            </div>\r\n            <div class=\"col-12 col-lg-5\">\r\n                <div class=\"content-wrapper\">\r\n                    <h2 class=\"mbr-section-title mbr-fonts-style\"\r\n                        data-app-selector=\".mbr-section-title\"\r\n                        mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\r\n                        <b>The number of classrooms in an educational institute can vary widely</b>\r\n                    </h2>\r\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\"\r\n                       data-app-selector=\".mbr-text\">\r\n                        Classrooms in an educational institute will depend on its academic offerings, extracurricular\r\n                        activities, and the overall educational philosophy. It's common for larger institutes to have a\r\n                        diverse range of classrooms to accommodate various subjects.\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"col-12 col-lg-5\">\r\n                <div class=\"tabs-wrap\">\r\n                    <ul class=\"nav nav-tabs\" role=\"tablist\">\r\n                        <li mbr-buttons mbr-theme-style=\"display-4\" class=\"nav-item first mbr-fonts-style\"\r\n                            data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\">\r\n                            <a class=\"nav-link show active\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tab1\"\r\n                               aria-selected=\"true\">\r\n                                General <br> Classrooms\r\n                            </a>\r\n                        </li>\r\n                        <li mbr-buttons mbr-theme-style=\"display-4\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 1\"\r\n                            data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\">\r\n                            <a class=\"nav-link mbr-fonts-style\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tab2\"\r\n                               data-app-placeholder=\"Type Text\" aria-selected=\"true\">\r\n                                Science <br> Laboratories\r\n                            </a>\r\n                        </li>\r\n                        <li mbr-buttons mbr-theme-style=\"display-4\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 2\"\r\n                            data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\">\r\n                            <a class=\"nav-link mbr-fonts-style\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tab3\"\r\n                               data-app-placeholder=\"Type Text\" aria-selected=\"true\">\r\n                                Computer <br> Labs\r\n                            </a>\r\n                        </li>\r\n                        <li mbr-buttons mbr-theme-style=\"display-4\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 3\"\r\n                            data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\">\r\n                            <a class=\"nav-link mbr-fonts-style\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tab3\"\r\n                               data-app-placeholder=\"Type Text\" aria-selected=\"true\">\r\n                                Art <br> Studios\r\n                            </a>\r\n                        </li>\r\n                    </ul>\r\n                    <div class=\"tab-content\">\r\n                        <div id=\"tab1\" class=\"tab-pane in active\" role=\"tabpanel\">\r\n                            <div class=\"image-wrapper\">\r\n                                <img src=\"@PROJECT_PATH@/assets/images/image4.jpg\" alt=\"Mobirise\">\r\n                            </div>\r\n                        </div>\r\n                        <div id=\"tab2\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 1\">\r\n                            <div class=\"image-wrapper\">\r\n                                <img src=\"@PROJECT_PATH@/assets/images/image12.jpg\" alt=\"Mobirise\">\r\n                            </div>\r\n                        </div>\r\n                        <div id=\"tab3\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 2\">\r\n                            <div class=\"image-wrapper\">\r\n                                <img src=\"@PROJECT_PATH@/assets/images/image10.jpg\" alt=\"Mobirise\">\r\n                            </div>\r\n                        </div>\r\n                        <div id=\"tab4\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 3\">\r\n                            <div class=\"image-wrapper\">\r\n                                <img src=\"@PROJECT_PATH@/assets/images/image11.jpg\" alt=\"Mobirise\">\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</section>\r\n",
          "_cid": "u6l7Z54JMw",
          "_anchor": "tabs02-7k",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "content6",
          "_sourceTheme": "churchm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content6 churchm5\" group=\"Content\"\r\n         mbr-class=\"{'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\">\r\n\r\n    <mbr-parameters>\r\n        <header>Size</header>\r\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\r\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\r\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"0\"\r\n               condition=\"fullScreen == false\">\r\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\"\r\n               condition=\"fullScreen == false\">\r\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\r\n        <header>Show/Hide</header>\r\n        <input type=\"checkbox\" title=\"Box\" name=\"showBox\" checked>\r\n        <input type=\"color\" title=\"Border Color\" value=\"#ffffff\" name=\"border\" condition=\"showBox\" selected>\r\n        <input type=\"color\" title=\"Container BG\" value=\"#E0AE8A\" name=\"container\" selected>\r\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\r\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\r\n        <input type=\"checkbox\" title=\"Image\" name=\"showImage\" checked>\r\n        <header>Background</header>\r\n        <fieldset type=\"background\" name=\"bg\" parallax>\r\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/churchm5/components/_images/background1.jpg\" parallax>\r\n            <input type=\"color\" title=\"Color\" value=\"#fdfcfa\" selected>\r\n        </fieldset>\r\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\r\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/churchm5/components/_images/background1.jpg\" name=\"fallBackImage\"\r\n               condition=\"bg.type === 'video'\">\r\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\r\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\"\r\n               condition=\"overlay && bg.type !== 'color'\">\r\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.3\"\r\n               condition=\"overlay && bg.type !== 'color'\">\r\n    </mbr-parameters>\r\n\r\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\r\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\"\r\n         mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\r\n    </div>\r\n\r\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\r\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\r\n            <div class=\"col-12 col-lg-1 card\">\r\n                <div class=\"box-wrapper\">\r\n                    <p class=\"mbr-box mbr-fonts-style\" data-app-selector=\".mbr-box\"\r\n                       mbr-theme-style=\"display-2\" mbr-if=\"showBox\">\r\n                        <b>C</b>\r\n                    </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"col-12 col-lg-7 card\">\r\n                <div class=\"title-wrapper\">\r\n                    <p class=\"mbr-text mbr-fonts-style\"\r\n                       data-app-selector=\".mbr-text, .mbr-section-btn\"\r\n                       mbr-theme-style=\"display-7\" mbr-if=\"showText\">\r\n                        Religious centers play a crucial role in the spiritual and communal life of the church. They\r\n                        are places where believers can come together to worship, pray, and engage in various\r\n                        religious activities. In this article, we will explore the importance of religious centers\r\n                        in the church.\r\n                        <br> <br> <br>\r\n                        Religious centers in the church serve several purposes. First and foremost, they provide a\r\n                        physical space for worship and religious rituals. These spaces are often designed to create\r\n                        an atmosphere of reverence and awe, with symbols and decorations that reflect the beliefs\r\n                        and traditions of the church. They may also be used for other religious activities, such as\r\n                        study groups, youth groups, or choir rehearsals.\r\n                        <br> <br>\r\n                        Religious centers also serve as a gathering place for the church community.\r\n                    </p>\r\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\">\r\n                        <a class=\"btn btn-warning-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\r\n                            <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\r\n                            START NOW!\r\n                        </a>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div class=\"col-12 col-md-4 card\">\r\n                <div class=\"image-wrapper\" mbr-if=\"showImage\">\r\n                    <img src=\"@PROJECT_PATH@/assets/images/image2.jpg\" alt=\"Mobirise\">\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0",
                "@media (max-width: 992px)": {
                  "padding": "0"
                }
              }
            },
            ".container": {
              "@media (max-width: 992px)": {
                "padding": "0"
              }
            },
            ".row": {
              "margin": "0"
            },
            ".card": {
              "border-radius": "0",
              "padding": "0",
              ".box-wrapper": {
                "background-color": "@container",
                "height": "100%",
                ".mbr-box": {
                  "height": "130px",
                  "display": "flex",
                  "align-items": "center",
                  "justify-content": "center",
                  "border-bottom": "1px solid @border",
                  "margin-bottom": "20px"
                }
              },
              ".title-wrapper": {
                "padding": "145px 100px",
                "@media (max-width: 992px)": {
                  "padding": "30px 16px"
                },
                ".mbr-text": {
                  "margin-bottom": "0"
                },
                ".mbr-section-btn": {
                  "margin-top": "70px",
                  "@media (max-width: 992px)": {
                    "margin-top": "40px"
                  }
                }
              },
              ".image-wrapper": {
                "padding": "90px 0",
                "@media (max-width: 992px)": {
                  "padding": "0"
                },
                "img": {
                  "height": "380px",
                  "object-fit": "cover",
                  "@media (max-width: 992px)": {
                    "height": "300px"
                  }
                }
              }
            },
            ".mbr-text": {
              "color": "#263652"
            },
            ".mbr-box": {
              "color": "#ffffff"
            }
          },

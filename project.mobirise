            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".row": {
              "padding": "0 110px",
              "@media (max-width: 992px)": {
                "padding": "0 12px"
              }
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".image-wrapper": {
              "position": "relative",
              "& when (@decor)": {
                "&::before": {
                  "content": "''",
                  "display": "block",
                  "background-color": "@decor_1",
                  "position": "absolute",
                  "bottom": "0",
                  "left": "0",
                  "width": "150px",
                  "height": "150px",
                  "& when (@reverseContent)": {
                    "left": "auto",
                    "right": "0"
                  },
                  "@media (max-width: 992px)": {
                    "display": "none"
                  }
                },
                "&::after": {
                  "content": "''",
                  "display": "block",
                  "background-color": "@decor_2",
                  "position": "absolute",
                  "bottom": "25px",
                  "left": "25px",
                  "width": "100px",
                  "height": "100px",
                  "border-radius": "0 100% 0 0",
                  "& when (@reverseContent)": {
                    "left": "auto",
                    "right": "25px",
                    "border-radius": "100% 0 0 0"
                  },
                  "@media (max-width: 992px)": {
                    "display": "none"
                  }
                }
              },
              "img": {
                "max-width": "100%",
                "max-height": "500px",
                "object-fit": "cover",
                "border-radius": "0 0 0 100%",
                "& when (@reverseContent)": {
                  "border-radius": "0 0 100% 0"
                }
              }
            },
            ".text-wrapper": {
              "padding": "60px 0 0 100px",
              "@media (max-width: 992px)": {
                "padding": "60px 0 0"
              },
              "& when (@reverseContent)": {
                "padding": "60px 100px 0 0",
                "@media (max-width: 992px)": {
                  "padding": "60px 0 0"
                }
              },
              ".mbr-section-title": {
                "margin-bottom": "15px"
              },
              ".mbr-text": {
                "margin-bottom": "0"
              }
            },
            ".mbr-section-title": {
              "color": "#ee2947"
            },
            ".mbr-text": {
              "color": "#1e4381"
            }
          },

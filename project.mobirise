                "@media (max-width: 992px)": {
                  "padding": "0 24px"
                }
              }
            },
            "@media (max-width: 992px)": {
              ".container": {
                "@media (max-width: 992px)": {
                  "padding": "0 24px"
                }
              }
            },
            ".row": {
              "position": "relative",
              "padding": "32px",
              "margin": "0",
              "@media (max-width: 992px)": {
                "padding": "24px"
              },
              "&::before": {
                "content": "''",
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "100%",
                "background-color": "@container",

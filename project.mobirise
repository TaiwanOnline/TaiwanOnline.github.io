        {
          "_name": "content07",
          "_sourceTheme": "dinerm4",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content07 dinerm4_content07\" group=\"Content\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\"\n    mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        \n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"4\" >\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"2\" >\n        <header>Show / Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" >\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked >\n        <input type=\"checkbox\" title=\"Meta\" name=\"showMeta\" checked >\n        <input type=\"checkbox\" title=\"Link\" name=\"showLink\" >\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/dinerm4/components/_images/background3.jpg\" parallax >\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected >\n            <input type=\"video\" title=\"Video\" value=\"https://www.youtube.com/watch?v=36YgDDJ7XSc\" >\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/dinerm4/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" checked condition=\"bg.type !== 'color'\" >\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#efefef\"\n            condition=\"overlay && bg.type !== 'color'\" >\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\"\n            condition=\"overlay && bg.type !== 'color'\" >\n        \n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\"\n        mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n\n    <div class=\"container\">\n        <div class=\"row\">\n            <div class=\"card item features-image col-12 col-md-12 col-lg-8\">\n                <div class=\"item-wrapper\">\n                    <div class=\"card-img\">\n                        <img src=\"@PROJECT_PATH@/assets/images/02.jpg\" alt=\"Mobirise\" >\n                    </div>\n                    <div class=\"card-box pt-4\">\n                        <div class=\"wrapper\" mbr-if=\"showMeta\">\n                            <div class=\"icon-wrap\">\n                                <span mbr-icon class=\"mbr-iconfont mobi-mbri-map-pin mobi-mbri\"></span>\n                                <h6 mbr-text class=\"location mbr-regular mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                                    data-app-selector=\".location, .icon-wrap\">\n                                    THAI\n                                </h6>\n                            </div>\n\n                            <div class=\"icon-wrap icon-padding\">\n                                <span mbr-icon class=\"mbr-iconfont mobi-mbri-timer mobi-mbri\"></span>\n                                <h6 mbr-text class=\"location mbr-regular mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                                    data-app-selector=\".location, .icon-wrap\">\n                                    23, DECEMBER, 2025\n                                </h6>\n                            </div>\n                        </div>\n\n                        <h4 class=\"card-title align-left pb-3 mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-7\"\n                            mbr-if=\"showTitle\" data-app-selector=\".card-title, .card-img\">\n                            The only thing that will possibly be different\n                        </h4>\n                        <p class=\"mbr-text align-left mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\"\n                            data-app-selector=\".mbr-text, .link\">\n                            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec ullamcorper neque dapibus\n                            ipsum semper, sit amet luctus\n                            turpis porttitor. Ut libero ante, varius quis ligula in, aliquet consectetur tortor. Proin\n                            aliquet neque nibh, pretium\n                            rutrum quam mattis. Morbi vitae sodales metus. Pellentesque vel elit ullamcorper,\n                            pellentesque magna nec, dictum purus.\n                        </p>\n\n                        <div class=\"link-align align-left\" mbr-if=\"showLink\">\n                            <div class=\"link-inline\">\n                                <div class=\"link-wrap\">\n                                    <h5 mbr-text class=\"link mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                                        data-app-selector=\".link, .link-wrap, .link-align\">\n                                        READ MORE\n                                    </h5>\n                                    <span mbr-icon class=\"mbr-iconfont mbr-bold mobi-mbri-right mobi-mbri\"></span>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-text": {
              "color": "#767676"
            },
            ".card-subtitle": {
              "margin": "0"
            },
            "img": {
              "object-fit": "cover",
              "max-height": "400px",
              "widht": "100%",
              "transition": "all 0.6s"
            },
            ".link": {
              "transition": "all 0.3s"
            },
            ".link-inline": {
              "display": "inline-block",
              "width": "fit-content"
            },
            ".mbr-section-btn": {
              "span": {
                "order": "2",
                "padding": "0",
                "margin-left": "1rem"
              },
              ".btn": {
                "border": "0px",
                "&:hover": {
                  "background": "inherit !important",
                  "color": "inherit !important"
                }
              }
            },
            "h4, h6, h5": {
              "margin": "0"
            },
            ".link-wrap": {
              "display": "flex",
              "width": "fit-content",
              "align-items": "center",
              "span": {
                "margin-left": "0.6rem",
                "transition": "all 0.3s"
              },
              "&:hover": {
                "color": "@primaryColor",
                ".link": {
                  "color": "@primaryColor"
                },
                "span": {
                  "transform": "translateX(5px)"
                }
              }
            },
            ".wrapper": {
              "display": "flex",
              "margin-bottom": "0.8rem"
            },
            ".icon-wrap": {
              "display": "flex",
              "align-items": "center",
              "span": {
                "margin-right": "8px"
              }
            },
            ".icon-padding": {
              "padding-left": "2rem"
            },
            ".card": {
              "margin-bottom": "2rem"
            },
            ".row": {
              "justify-content": "center"
            },
            ".location, .icon-wrap": {
              "color": "#e7272d"
            },
            ".link, .link-wrap, .link-align": {
              "color": "#0e0e0e"
            },
            "@media (max-width: 767px)": {
              ".wrapper": {
                "flex-direction": "column",
                "align-items": "center"
              },
              ".icon-padding": {
                "padding-left": "0rem"
              },
              ".card-box": {
                "padding": "0"
              }
            },
            "H2": {
              "color": "#e7272d"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            }
          },
          "_cid": "u6li4c399d",

        {
          "_name": "article010",
          "_sourceTheme": "offerm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"offerm5 article10\" group=\"Article\" mbr-class=\"{'mbr-fullscreen': fullScreen}\"\r\n    data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\">\r\n    <mbr-parameters>\r\n\r\n\r\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\r\n        <header>Size</header>\r\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\r\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"7\"\r\n            condition=\"fullScreen == false\">\r\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"7\"\r\n            condition=\"fullScreen == false\">\r\n        <header>Show/Hide</header>\r\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\r\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubTitle\" checked>\r\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\r\n        <input type=\"checkbox\" title=\"Link\" name=\"showButtons\" checked>\r\n\r\n        <input type=\"range\" inline title=\"Tags\" name=\"tags\" min=\"0\" max=\"5\" step=\"1\" value=\"4\">\r\n        <input type=\"color\" name=\"tag1\" title=\"Tag 1 Color\" value=\"#30c7bf\" selected condition=\"tags > 0\">\r\n        <input type=\"color\" name=\"tag2\" title=\"Tag 2 Color\" value=\"#fc898c\" selected condition=\"tags > 1\">\r\n        <input type=\"color\" name=\"tag3\" title=\"Tag 3 Color\" value=\"#00004c\" selected condition=\"tags > 2\">\r\n        <input type=\"color\" name=\"tag4\" title=\"Tag 4 Color\" value=\"#30c7bf\" selected condition=\"tags > 3\">\r\n        <input type=\"color\" name=\"tag5\" title=\"Tag 5 Color\" value=\"#fc898c\" selected condition=\"tags > 4\">\r\n        <header>Background</header>\r\n        <fieldset type=\"background\" name=\"bg\">\r\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/offerm5/components/_images/background2.jpg\">\r\n            <input type=\"color\" title=\"Color\" value=\"#fffaee\" selected>\r\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\r\n        </fieldset>\r\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\r\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/offerm5/components/_images/background1.jpg\" name=\"fallBackImage\"\r\n            condition=\"bg.type === 'video'\">\r\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\r\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#fafafa\"\r\n            condition=\"overlay && bg.type !== 'color'\">\r\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0\"\r\n            condition=\"overlay && bg.type !== 'color'\">\r\n        <!-- End block parameters -->\r\n    </mbr-parameters>\r\n\r\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\r\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\"\r\n        bg-color=\"{{overlayColor}}\"></div>\r\n    <div class=\"container\">\r\n        <div class=\"row\"\r\n            mbr-class=\"{'justify-content-center' : alignContent == 2, 'justify-content-end' : alignContent == 3}\">\r\n            <div class=\"col-lg-6 col-sm-12 col-md-12 d-flex column md-pb\">\r\n\r\n                <img class=\"mbr-temp\" src=\"@PROJECT_PATH@/assets/images/04.jpg\" alt=\"Mobirise\">\r\n\r\n            </div>\r\n            <div class=\"col-lg-6 col-sm-12 col-md-12 m-auto\">\r\n                <div class=\"tag-wrapper d-flex\">\r\n                    <h4 class=\"tag align-left tag1 mbr-semibold mbr-fonts-style\" mbr-theme-style=\"display-4\"\r\n                        mbr-if=\"tags > 0\" data-app-selector=\".tag\">OFFERS</h4>\r\n                    <h4 class=\"tag align-left tag2 mbr-semibold mbr-fonts-style\" mbr-theme-style=\"display-4\"\r\n                        mbr-if=\"tags > 1\" data-app-selector=\".tag\">FINANCE</h4>\r\n                    <h4 class=\"tag align-left tag3 mbr-semibold mbr-fonts-style\" mbr-theme-style=\"display-4\"\r\n                        mbr-if=\"tags > 2\" data-app-selector=\".tag\">CONTACTS</h4>\r\n                    <h4 class=\"tag align-left tag4 mbr-semibold mbr-fonts-style\" mbr-theme-style=\"display-4\"\r\n                        mbr-if=\"tags > 3\" data-app-selector=\".tag\">INFO</h4>\r\n                    <h4 class=\"tag align-left tag5 mbr-semibold mbr-fonts-style\" mbr-theme-style=\"display-4\"\r\n                        mbr-if=\"tags > 4\" data-app-selector=\".tag\">HELP</h4>\r\n                </div>\r\n                <h2 class=\"mbr-fonts-style align-left mbr-semibold pb-2 pt-2 mbr-section-title\"\r\n                    mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">Lorem ipsum\r\n                    dolor sit amet</h2>\r\n                <h3 class=\"mbr-section-subtitle mbr-regular mbr-fonts-style align-left pb-2\" mbr-if=\"showSubTitle\"\r\n                    mbr-theme-style=\"display-4\" data-app-selector=\".mbr-section-subtitle\">Mon 22 February 2021</h3>\r\n                <p class=\"mbr-text mbr-fonts-style align-left pb-3\" mbr-if=\"showText\" mbr-theme-style=\"display-4\"\r\n                    data-app-selector=\".mbr-text\">\r\n                    Consectetur adipiscing elit. Aliquam vitae risus. Nulla nulla elit,\r\n                    tristique turpis. Maecenas non porttitor quam, a rutrum arcu. Maecenas congue vel metus\r\n                    ac accumsan. Donec feugiat ac nisi eleifend semper. Nullam eget consectetur.</p>\r\n\r\n                <p class=\"link mbr-fonts-style mbr-regular align-left pb-3\" mbr-if=\"showButtons\"\r\n                    mbr-theme-style=\"display-4\" data-app-selector=\".link\">\r\n                    Read more</p>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 15px)",
              "padding-bottom": "(@paddingBottom * 15px)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "img": {
              "object-fit": "cover",
              "width": "90%",
              "@media (max-width: 992px)": {
                "width": "100%"
              }
            },
            ".link": {
              "text-decoration": "underline"
            },
            ".tag-wrapper": {
              "flex-wrap": "wrap",
              "@media (max-width: 767px)": {
                "justify-content": "center"
              }

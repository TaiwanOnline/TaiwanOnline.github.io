          "_name": "features02",
          "_sourceTheme": "visionm4",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features2\" group=\"Features\" data-bg-video=\"{{bg.type == 'video' &amp;&amp; bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline=\"\" title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline=\"\" title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked=\"\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked=\"\">\n        <input type=\"checkbox\" title=\"Icons\" name=\"showIcon\" checked=\"\">\n        <select title=\"Items\" name=\"cardsAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\" selected=\"\">3</option>\n        </select>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax=\"\">\n            <input type=\"image\" title=\"Image\" value=\"../_images/background3.jpg\" parallax=\"\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected=\"\">\n            <input type=\"video\" title=\"Video\" value=\"https://www.youtube.com/watch?v=36YgDDJ7XSc\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked=\"\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n        <input type=\"range\" inline=\"\" title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay &amp;&amp; bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-lg-4 col-md-7 col1 align-left my-auto\">\n                <div class=\"row justify-content-center\">\n                    <div class=\"card col-12 col-md-12 col-lg-12 md-pb\" mbr-if=\"cardsAmount > 0\">\n                        <div class=\"card-wrapper\">\n                            <span mbr-icon=\"\" class=\"mbr-iconfont mobi-mbri-right mobi-mbri\" mbr-if=\"showIcon\"></span>\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style mb-2\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\">Machine Learning</h4>\n                                <h5 class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".card-text\">Lorem ipsum dolor sit amet, consectetur adipiscing\n                                    aliquet\n                                    elit.</h5>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card col-12 col-md-12 col-lg-12 md-pb\" mbr-if=\"cardsAmount > 1\">\n                        <div class=\"card-wrapper\">\n                            <span mbr-icon=\"\" class=\"mbr-iconfont mobi-mbri-right mobi-mbri\" mbr-if=\"showIcon\"></span>\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style mb-2\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\">Computer Vision</h4>\n                                <h5 class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".card-text\">Lorem ipsum dolor sit amet, consectetur adipiscing\n                                    aliquet\n                                    elit.</h5>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card col-12 col-md-12 col-lg-12 md-pb\" mbr-if=\"cardsAmount > 2\">\n                        <div class=\"card-wrapper\">\n                            <span mbr-icon=\"\" class=\"mbr-iconfont mobi-mbri-right mobi-mbri\" mbr-if=\"showIcon\"></span>\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style mb-2\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\">Internet Of Things</h4>\n                                <h5 class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".card-text\">Lorem ipsum dolor sit amet, consectetur adipiscing\n                                    aliquet\n                                    elit.</h5>\n                            </div>\n\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-lg-4 col-md-7 md-pb\">\n                <img src=\"../_images/img/phone2.png\" alt=\"Mobirise\">\n            </div>\n            <div class=\"col-lg-4 col-md-7 col2 align-right my-auto\">\n                <div class=\"row justify-content-center\">\n                    <div class=\"card col-12 col-md-12 col-lg-12 md-pb\" mbr-if=\"cardsAmount > 0\">\n                        <div class=\"card-wrapper\">\n\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style mb-2\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\">Internet Of Things</h4>\n                                <h5 class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".card-text\">Lorem ipsum dolor sit amet, consectetur adipiscing\n                                    aliquet\n                                    elit.</h5>\n                            </div>\n                            <span mbr-icon=\"\" class=\"mbr-iconfont mobi-mbri-left mobi-mbri\" mbr-if=\"showIcon\"></span>\n                        </div>\n                    </div>\n                    <div class=\"card col-12 col-md-12 col-lg-12 md-pb\" mbr-if=\"cardsAmount > 1\">\n                        <div class=\"card-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style mb-2\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\">Machine Learning</h4>\n                                <h5 class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".card-text\">Lorem ipsum dolor sit amet, consectetur adipiscing\n                                    aliquet\n                                    elit.</h5>\n                            </div>\n                            <span mbr-icon=\"\" class=\"mbr-iconfont mobi-mbri-left mobi-mbri\" mbr-if=\"showIcon\"></span>\n                        </div>\n                    </div>\n                    <div class=\"card col-12 col-md-12 col-lg-12 md-pb\" mbr-if=\"cardsAmount > 2\">\n                        <div class=\"card-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style mb-2\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\">Computer Vision</h4>\n                                <h5 class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".card-text\">Lorem ipsum dolor sit amet, consectetur adipiscing\n                                    aliquet\n                                    elit.</h5>\n                            </div>\n                            <span mbr-icon=\"\" class=\"mbr-iconfont mobi-mbri-left mobi-mbri\" mbr-if=\"showIcon\"></span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",

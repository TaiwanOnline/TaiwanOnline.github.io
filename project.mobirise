              },
              ".item": {
                "padding": "32px",
                "border-bottom": "1px solid @border",
                "@media (max-width: 992px)": {
                  "padding": "24px"
                },
                "&:last-child": {
                  "border": "none"
                },
                ".item-wrapper": {
                  "display": "flex",
                  "justify-content": "space-between",
                  "align-items": "center",
                  "@media (max-width: 992px)": {
                    "display": "block"
                  },
                  ".item-img": {
                    "background-color": "@image",
                    "border-radius": ".5rem",
                    "margin-right": "48px",
                    "@media (max-width: 992px)": {
                      "margin": "0 0 24px 0"
                    },
                    "img": {
                      "width": "150px",
                      "height": "120px",
                      "object-fit": "contain",
                      "margin": "0 auto"
                    }
                  },
                  ".item-content": {
                    ".card-title": {
                      "margin-bottom": "8px"
                    },
                    ".card-text": {
                      "margin-bottom": "0"
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#F9F6E0"
            },
            ".mbr-desc": {
              "color": "#E0B548",
              "text-align": "right"
            },
            ".mbr-text": {
              "color": "#F9F6E0",
              "text-align": "right"
            },
            ".card-title": {
              "color": "#F9F6E0"
            },
            ".card-text": {
              "color": "#F9F6E0"
            },
            ".mbr-section-title, .mbr-section-btn": {
              "text-align": "right"
            }
          },
          "_name": "features04",
          "_sourceTheme": "fabm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features04 fabm5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Description\" name=\"showDesc\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"color\" title=\"Border Color\" value=\"#72716b\" name=\"border\">\n        <input type=\"color\" title=\"Container BG\" value=\"#ffffff\" name=\"container\">\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Card Title\" name=\"showCardTitle\" checked>\n        <input type=\"checkbox\" title=\"Card Text\" name=\"showCardText\" checked>\n        <input type=\"color\" title=\"Image BG\" value=\"#F9F6E0\" name=\"image\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\" selected parallax>\n            <input type=\"color\" title=\"Color\" value=\"#474A48\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-4 card\">\n                <div class=\"content-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                        <b>Our Clients</b>\n                    </h2>\n                    <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showDesc\" data-app-selector=\".mbr-desc\">\n                        Here are some examples of customers and the reasons they might contact a logistics company.\n                    </p>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                        Logistics companies provide a wide range of services to meet the diverse needs of their\n                        customers. Various types of companies and organizations may contact logistics firms for\n                        assistance. These examples illustrate the wide array of industries and organizations that rely\n                        on logistics companies to manage and optimize their supply chains, ensuring the smooth flow of\n                        goods and materials from point of origin to destination.\n                    </p>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                        <a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                            <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                            VIEW MORE\n                        </a>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-8 card\">\n                <div class=\"items\">\n                    <div class=\"item features-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"item-img\">\n                                <img src=\"../_images/fab/1.png\" alt=\"Mobirise Website Builder\">\n                            </div>\n                            <div class=\"item-content\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">\n                                    <b>E-commerce Retailers</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Example Customers: Amazon, eBay, Shopify stores.\n                                    Services Needed: Order fulfillment, warehousing, last-mile delivery, returns\n                                    management, and inventory optimization.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"item-img\">\n                                <img src=\"../_images/fab/2.png\" alt=\"Mobirise Website Builder\">\n                            </div>\n                            <div class=\"item-content\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">\n                                    <b>Manufacturers</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Example Customers: Automotive manufacturers, electronics companies.\n                                    Services Needed: Transportation, supply chain optimization, raw material\n                                    procurement, and distribution to retailers or wholesalers.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"item-img\">\n                                <img src=\"../_images/fab/3.png\" alt=\"Mobirise Website Builder\">\n                            </div>\n                            <div class=\"item-content\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">\n                                    <b>Wholesalers and Distributors</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Example Customers: Food distributors, medical equipment wholesalers.\n                                    Services Needed: Efficient distribution, inventory management, cross-docking, and\n                                    order consolidation.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"item-img\">\n                                <img src=\"../_images/fab/4.png\" alt=\"Mobirise Website Builder\">\n                            </div>\n                            <div class=\"item-content\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">\n                                    <b>Importers and Exporters</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Example Customers: Importers of consumer electronics, exporters of agricultural\n                                    products.\n                                    Services Needed: Customs brokerage, international freight forwarding, compliance\n                                    with trade regulations, and documentation support.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"item-img\">\n                                <img src=\"../_images/fab/5.png\" alt=\"Mobirise Website Builder\">\n                            </div>\n                            <div class=\"item-content\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">\n                                    <b>Food and Beverage Industry</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Example Customers: Restaurants, grocery store chains.\n                                    Services Needed: Temperature-controlled logistics, perishable goods handling, and\n                                    inventory rotation.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"item-img\">\n                                <img src=\"../_images/fab/6.png\" alt=\"Mobirise Website Builder\">\n                            </div>\n                            <div class=\"item-content\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">\n                                    <b>Construction and Engineering</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Example Customers: Construction firms, engineering companies.\n                                    Services Needed: Heavy equipment transport, project logistics, and site-specific\n                                    deliveries.\n                                </p>\n                            </div>\n                        </div>\n                    </div><div class=\"item features-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"item-img\">\n                                <img src=\"@PROJECT_PATH@/assets/images/mbr-1920x1280.jpg\" alt=\"Mobirise Website Builder\" data-slide-to=\"6\" data-bs-slide-to=\"7\">\n                            </div>\n                            <div class=\"item-content\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">\n                                    <b>Construction and Engineering</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Example Customers: Construction firms, engineering companies.\n                                    Services Needed: Heavy equipment transport, project logistics, and site-specific\n                                    deliveries.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "u442tj4rGy",
          "_anchor": "features04-9g",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "design-block",
          "_sourceTheme": "powerm5",
          "_styles": {
            "padding-top": "(@paddingTop * 25px)",
            "padding-bottom": "(@paddingBottom * 25px)",
            "& when (@bg-type = 'color')": {
              "& when not (@transp)": {
                "background": "linear-gradient(@angle * 1deg, @bg-value, @color2)"
              },
              "& when (@transp)": {
                "background": "transparent"
              }
            },
            ".news": {
              "width": "(@newswidth * 1px)",
              "background-color": "@newscolor",
              "height": "(@newsheight * 1px)"
            },
            ".news-scroll a": {
              "text-decoration": "none"
            },
            ".dot": {
              "height": "6px",
              "width": "6px",
              "margin-left": "3px",
              "margin-right": "3px",
              "margin-top": "2px !important",
              "background-color": "@dotscolor",
              "border-radius": "50%",
              "display": "inline-block"
            },
            "DIV": {
              "color": "#ffffff"
            },
            ".mbr-text": {
              "color": "#030303"
            },
            ".mbr-section-subtitle": {
              "color": "#ffffff"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" mbr-id=\"_anchor\" class=\"mbr-section article content1\">\n\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"0\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"0\">\n        <header>News</header>\n                <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" name=\"textWidth\" title=\"Box Width\" min=\"4\" max=\"12\" value=\"12\" step=\"1\">\n        <input type=\"range\" inline title=\"News Width\" name=\"newswidth\" min=\"100\" max=\"250\" step=\"1\" value=\"250\">\n                <input type=\"range\" inline title=\"News Height\" name=\"newsheight\" min=\"6\" max=\"300\" step=\"1\" value=\"31\">\n        <input type=\"color\" title=\"News Color\" name=\"newscolor\" value=\"#123794\">\n        <input type=\"color\" title=\"Dots Color\" name=\"dotscolor\" value=\"#d20320\">\n                \n\n        <header>Texte</header>\n      <input type=\"color\" title=\"Text BG Color\" name=\"textbgcolor\" value=\"#ffffff\">\n\n                              <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"color\" title=\"Background Color\" value=\"#554d4f\" selected>\n      </fieldset>\n        \n         <input type=\"color\" title=\"Color 2\" name=\"color2\" value=\"#232323\" condition=\"bg.type == 'color'\">\n         <input type=\"range\" name=\"angle\" title=\"Angle\" min=\"0\" max=\"270\" value=\"0\" step=\"1\" condition=\"bg.type == 'color'\">\n\t\t <input type=\"checkbox\" title=\"Background Transparent\" name=\"transp\" condition=\"bg.type == 'color'\">\n        </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n<div class=\"container mt-10 col-lg-{{textWidth}}\">\n    <div class=\"row\">\n        <div class=\"col-md-12 \">\n            <div class=\"d-flex justify-content-between align-items-center breaking-news\" style=\"background: {{textbgcolor}}\">\n               \n                <marquee class=\"news-scroll\" behavior=\"scroll\" direction=\"left\" onmouseover=\"this.stop();\" onmouseout=\"this.start();\"> <a href=\"#\"></a><p class=\"mbr-text mbr-fonts-style mb-0\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">Sed faucibus turpis in eu. Varius duis at consectetur lorem donec massa sapien<span class=\"dot\"></span> Scelerisque mauris pellentesque pulvinar pellentesque habitant morbi tristique.<span class=\"dot\"></span> Sodales ut eu seminteger vitae. Malesuada fames ac turpis egestas sed tempus urna<span class=\"dot\"></span>  Sodales ut etiam sit amet nislpurus in.</p></marquee>\n            </div>\n        </div>\n    </div>\n\n     </div>\n\n\n   \n</div></section>",
          "_JSplaceholders": [],
          "_PHPplaceholders": [],
          "_anchor": "design-block-9n",
          "_isUserblock": true,
          "_cid": "u4goBHaqol",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0 32px",
                "@media (max-width: 992px)": {
                  "padding": "0 24px"
                }
              }
            },
            "@media (max-width: 992px)": {
              ".container": {
                "@media (max-width: 992px)": {
                  "padding": "0 24px"
                }
              }
            },
            ".row": {
              "@media (max-width: 992px)": {
                "border": "none"
              }
            },
            ".content-wrapper": {
              "padding": "0 32px 32px",
              "@media (max-width: 992px)": {
                "padding": "0 24px 24px"
              },
              ".mbr-section-title": {
                "margin-bottom": "16px",
                "@media (max-width: 992px)": {
                  "text-align": "left"
                }
              },
              ".mbr-text": {
                "margin-bottom": "0",
                "@media (max-width: 992px)": {
                  "text-align": "left"
                }
              }
            },
            ".panel-group": {
              "display": "grid",
              "grid-template-columns": "1fr 1fr 1fr",
              "@media (max-width: 992px)": {
                "grid-template-columns": "1fr 1fr"
              },
              "@media (max-width: 768px)": {
                "display": "block"
              },
              ".card": {
                "padding": "32px",
                "border-top": "1px solid @border",
                "border-right": "1px solid @border",
                "border-radius": "0 !important",
                "justify-content": "center",
                "align-items": "center",
                "min-height": "300px",
                "&:nth-child(3n)": {
                  "border-right": "none"
                },
                "@media (max-width: 992px)": {
                  "padding": "24px",
                  "border-right": "1px solid @border !important",
                  "&:nth-child(2n)": {
                    "border-right": "none !important"
                  }
                },
                "@media (max-width: 768px)": {
                  "min-height": "200px",
                  "border-right": "none !important"
                },
                ".card-header": {
                  "padding": "0",
                  "border": "none",
                  "background-color": "transparent",
                  ".panel-title": {
                    "display": "block",
                    "&:not(.collapsed)": {
                      ".panel-title-edit": {
                        "color": "@active"
                      }
                    },
                    "&:hover": {
                      ".panel-title-edit": {
                        "color": "@active"
                      }
                    },
                    ".panel-title-edit": {
                      "transition": "all 0.3s ease-in-out",
                      "margin": "0"
                    }
                  }
                },
                ".panel-collapse": {
                  ".panel-body": {
                    "padding-top": "8px",
                    ".panel-text": {
                      "margin-bottom": "0"
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#F9F6E0"
            },
            ".mbr-text": {
              "color": "#F9F6E0"
            },
            ".panel-title-edit": {
              "color": "#F9F6E0"
            },
            ".panel-text": {
              "color": "#F9F6E0"
            }
          },
          "_name": "features07",
          "_sourceTheme": "fabm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features07 fabm5\" group=\"Features\" plugins=\"mbr-switch-arrow, mobirise-icons2\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline=\"\" title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline=\"\" title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked=\"\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked=\"\">\n        <header>Cards</header>\n        <select title=\"Amount\" name=\"cardAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\">6</option>\n            <option value=\"7\">7</option>\n            <option value=\"8\">8</option>\n            <option value=\"9\" selected=\"\">9</option>\n        </select>\n        <input type=\"color\" title=\"Active Color\" value=\"#E0B548\" name=\"active\">\n        <input type=\"color\" title=\"Border Color\" value=\"#72716b\" name=\"border\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax=\"\">\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\" selected=\"\" parallax=\"\">\n            <input type=\"color\" title=\"Color\" value=\"#474A48\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n        <input type=\"range\" inline=\"\" title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay &amp;&amp; bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"content-wrapper\" mbr-if=\"showTitle || showText\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                        <b>FAQ</b>\n                    </h2>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                        Questions our team often encounters.\n                    </p>\n                </div>\n            </div>\n            <div class=\"col-12\">\n                <div id=\"bootstrap-accordion\" class=\"panel-group accordionStyles accordion\" role=\"tablist\" aria-multiselectable=\"true\">\n                    <div class=\"card\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingOne\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse1\" aria-expanded=\"false\" aria-controls=\"collapse1\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit, .panel-title\">\n                                    <b>What is logistics, and what does a logistics company do?</b>\n                                </h4>\n                            </a>\n                        </div>\n                        <div id=\"collapse1\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingOne\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    This fundamental question seeks an explanation of the logistics industry and the\n                                    specific services provided by the company.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 1\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingTwo\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse2\" aria-expanded=\"false\" aria-controls=\"collapse2\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit, .panel-title\">\n                                    <b>How can logistics services benefit my business?</b>\n                                </h4>\n                            </a>\n                        </div>\n                        <div id=\"collapse2\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingTwo\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Businesses often want to understand how logistics can improve their supply chain\n                                    efficiency, reduce costs, and enhance customer satisfaction.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 2\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse3\" aria-expanded=\"false\" aria-controls=\"collapse3\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit, .panel-title\">\n                                    <b>What types of transportation services do you offer?</b>\n                                </h4>\n                            </a>\n                        </div>\n                        <div id=\"collapse3\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Customers inquire about the various modes of transportation available, such as\n                                    trucking, shipping, air freight, and rail, to determine the most suitable option for\n                                    their needs.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 3\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingFour\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit, .panel-title\">\n                                    <b>Can you handle international shipments and customs clearance?</b>\n                                </h4>\n                            </a>\n                        </div>\n                        <div id=\"collapse4\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFour\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    For companies involved in international trade, understanding the logistics company's\n                                    capabilities in managing global logistics and navigating customs processes is\n                                    essential.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 4\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingFive\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse5\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit, .panel-title\">\n                                    <b>How do you ensure the security and safety of shipments?</b>\n                                </h4>\n                            </a>\n                        </div>\n                        <div id=\"collapse5\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFive\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Questions about security measures, tracking systems, and risk mitigation strategies\n                                    are common, especially for valuable or sensitive cargo.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 5\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingSix\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse6\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit, .panel-title\">\n                                    <b>What is the typical timeframe for shipping and delivery?</b>\n                                </h4>\n                            </a>\n                        </div>\n                        <div id=\"collapse6\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingSix\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Customers often want to know estimated delivery times for their shipments to plan\n                                    inventory and meet customer demands.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 6\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingSeven\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse7\" aria-expanded=\"false\" aria-controls=\"collapse7\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit, .panel-title\">\n                                    <b>What technology and tracking tools do you use for supply chain visibility?</b>\n                                </h4>\n                            </a>\n                        </div>\n                        <div id=\"collapse7\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingSeven\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Inquiries about technology solutions and tracking systems help customers monitor the\n                                    progress of their shipments in real-time.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 7\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingEight\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse8\" aria-expanded=\"false\" aria-controls=\"collapse8\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit, .panel-title\">\n                                    <b>How do you handle returns and reverse logistics?</b>\n                                </h4>\n                            </a>\n                        </div>\n                        <div id=\"collapse8\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingEight\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Customers seek information on the company's processes for managing product returns,\n                                    recycling, or disposal.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 8\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingNine\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core=\"\" href=\"#collapse9\" aria-expanded=\"false\" aria-controls=\"collapse9\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit, .panel-title\">\n                                    <b>Can you provide warehousing and inventory management services?</b>\n                                </h4>\n                            </a>\n                        </div>\n                        <div id=\"collapse9\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingNine\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Businesses may require storage solutions and inventory control as part of their\n                                    logistics services.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>\n",
          "_cid": "u442w8trhB",
          "_anchor": "features07-9i",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "design-block",
          "_sourceTheme": "powerm5",
          "_styles": {
            "padding-top": "(@paddingTop * 25px)",
            "padding-bottom": "(@paddingBottom * 25px)",
            "& when (@bg-type = 'color')": {
              "& when not (@transp)": {
                "background": "linear-gradient(@angle * 1deg, @bg-value, @color2)"
              },
              "& when (@transp)": {
                "background": "transparent"
              }
            },
            ".news": {
              "width": "(@newswidth * 1px)",
              "background-color": "@newscolor",
              "height": "(@newsheight * 1px)"
            },
            ".news-scroll a": {
              "text-decoration": "none"
            },
            ".dot": {
              "height": "6px",
              "width": "6px",
              "margin-left": "3px",
              "margin-right": "3px",
              "margin-top": "2px !important",
              "background-color": "@dotscolor",
              "border-radius": "50%",
              "display": "inline-block"
            },
            "DIV": {
              "color": "#ffffff"
            },
            ".mbr-text": {
              "color": "#030303"
            },
            ".mbr-section-subtitle": {
              "color": "#ffffff"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" mbr-id=\"_anchor\" class=\"mbr-section article content1\">\n\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"0\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"0\">\n        <header>News</header>\n                <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" name=\"textWidth\" title=\"Box Width\" min=\"4\" max=\"12\" value=\"12\" step=\"1\">\n        <input type=\"range\" inline title=\"News Width\" name=\"newswidth\" min=\"100\" max=\"250\" step=\"1\" value=\"250\">\n                <input type=\"range\" inline title=\"News Height\" name=\"newsheight\" min=\"6\" max=\"300\" step=\"1\" value=\"31\">\n        <input type=\"color\" title=\"News Color\" name=\"newscolor\" value=\"#123794\">\n        <input type=\"color\" title=\"Dots Color\" name=\"dotscolor\" value=\"#d20320\">\n                \n\n        <header>Texte</header>\n      <input type=\"color\" title=\"Text BG Color\" name=\"textbgcolor\" value=\"#ffffff\">\n\n                              <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"color\" title=\"Background Color\" value=\"#ffc036\" selected>\n      </fieldset>\n        \n         <input type=\"color\" title=\"Color 2\" name=\"color2\" value=\"#ffc036\" condition=\"bg.type == 'color'\">\n         <input type=\"range\" name=\"angle\" title=\"Angle\" min=\"0\" max=\"270\" value=\"0\" step=\"1\" condition=\"bg.type == 'color'\">\n\t\t <input type=\"checkbox\" title=\"Background Transparent\" name=\"transp\" condition=\"bg.type == 'color'\">\n        </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n<div class=\"container mt-10 col-lg-{{textWidth}}\">\n    <div class=\"row\">\n        <div class=\"col-md-12 \">\n            <div class=\"d-flex justify-content-between align-items-center breaking-news\" style=\"background: {{textbgcolor}}\">\n               \n                <marquee class=\"news-scroll\" behavior=\"scroll\" direction=\"left\" onmouseover=\"this.stop();\" onmouseout=\"this.start();\"> <a href=\"#\"></a><p class=\"mbr-text mbr-fonts-style mb-0\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">Sed faucibus turpis in eu. Varius duis at consectetur lorem donec massa sapien<span class=\"dot\"></span> Scelerisque mauris pellentesque pulvinar pellentesque habitant morbi tristique.<span class=\"dot\"></span> Sodales ut eu seminteger vitae. Malesuada fames ac turpis egestas sed tempus urna<span class=\"dot\"></span>  Sodales ut etiam sit amet nislpurus in.</p></marquee>\n            </div>\n        </div>\n    </div>\n\n     </div>\n\n\n   \n</div></section>",
          "_JSplaceholders": [],
          "_PHPplaceholders": [],
          "_anchor": "design-block-9r",
          "_isUserblock": true,
          "_cid": "u4gqMTxsjb",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "background": "linear-gradient(to bottom, @bg1, @bg2)",
            ".item-subtitle": {
              "line-height": "1.2",
              "color": "#232323"
            },
            ".item-title": {
              "border-bottom": "1px solid currentColor",
              "color": "#232323",
              "padding-bottom": "1rem",
              "margin-bottom": "2rem"
            },
            "img, .item-img": {
              "width": "100%",
              "& when (@autoSize)": {
                "height": "100%",
                "object-fit": "cover",
                "& when (@showCardTitle)": {
                  "height": "(@imageHeight * 100px)",
                  "object-fit": "cover"
                },
                "& when (@showCardSubtitle)": {
                  "height": "(@imageHeight * 100px)",
                  "object-fit": "cover"
                },
                "& when (@showText)": {
                  "height": "(@imageHeight * 100px)",
                  "object-fit": "cover"
                },
                "& when (@showButtons)": {
                  "height": "(@imageHeight * 100px)",
                  "object-fit": "cover"
                }
              }
            },
            ".item:focus, span:focus": {
              "outline": "none"
            },
            ".item": {
              "margin-bottom": "2rem",
              "@media (max-width: 767px)": {
                "margin-bottom": "1rem"
              }
            },
            "& when not (@spacing)": {
              ".row": {
                "margin-left": "0",
                "margin-right": "0"
              },
              ".item": {
                "padding": "0",
                "margin": "0"
              }
            },
            ".item-wrapper": {
              "position": "relative",
              "border-radius": "4px",
              "height": "100%",
              "display": "flex",
              "flex-flow": "column nowrap"
            },
            ".mbr-section-title": {
              "color": "#232323"
            },
            ".mbr-text, .mbr-section-btn": {
              "color": "#232323"
            },
            ".content-head": {
              "max-width": "800px"
            }
          },
          "_name": "features7",
          "_sourceTheme": "powerm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"powerm5 features7\" group=\"Features\">\n  <mbr-parameters>\n    <header>Size</header>\n    <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n    <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"4\">\n    <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"3\">\n    <select title=\"Columns\" name=\"cardsWidth\">\n      <option value=\"12\">1</option>\n      <option value=\"6\">2</option>\n      <option value=\"4\" selected>3</option>\n      <option value=\"3\">4</option>\n    </select>\n    <header>Show/Hide</header>\n    <input type=\"checkbox\" name=\"showTitle\" title=\"Title\">\n    <input type=\"checkbox\" name=\"showSubtitle\" title=\"Subtitle\">\n    <header>Cards</header>\n    <input type=\"checkbox\" name=\"autoSize\" title=\"Auto Size\" checked>\n    <input type=\"range\" name=\"imageHeight\" title=\"Height\" min=\"1\" max=\"5\" step=\"1\" value=\"4\" condition=\"autoSize && !(showButtons==false && showCardSubtitle==false && showCardTitle==false && showText==false)\">\n    <input type=\"checkbox\" title=\"Spacing\" name=\"spacing\" checked>\n    <input type=\"checkbox\" name=\"showCardTitle\" title=\"Title\" checked>\n    <input type=\"checkbox\" name=\"showCardSubtitle\" title=\"Subtitle\" checked>\n    <input type=\"checkbox\" name=\"showText\" title=\"Text\" checked>\n    <input type=\"checkbox\" name=\"showButtons\" title=\"Buttons\">\n    <header>Background</header>\n    <input type=\"color\" name=\"bg1\" title=\"Color 1\" value=\"#ffbf31\">\n    <input type=\"color\" name=\"bg2\" title=\"Color 2\" value=\"#ffffff\">\n  </mbr-parameters>\n  <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\"></div>\n  <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n    <div class=\"row justify-content-center\">\n      <div class=\"col-12 content-head\">\n        <div class=\"mbr-section-head mb-5\" mbr-if=\"showTitle || showSubtitle\">\n          <h4 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">\n            <b>Our News</b>\n          </h4>\n          <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mt-4 mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n            To add more cards, hover on a card and click 'Add items'\n          </h5>\n        </div>\n      </div>\n    </div>\n    <div class=\"row justify-content-center\">\n      <div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}} active\">\n        <div class=\"item-wrapper\">\n          <h5 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\">MARCH 30, 2025</h5>\n          <div class=\"item-img mb-3\">\n            <img src=\"../_images/video/video1.jpg\" alt=\"Mobirise Website Builder\" title>\n          </div>\n          <div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n\n            <h6 class=\"item-subtitle mbr-fonts-style pt-2 mb-3\" mbr-theme-style=\"display-5\" data-app-selector=\".item-subtitle\" mbr-if=\"showCardSubtitle\">\n              Lorem ipsum dolor sit amet, adipiscing faucibus elit.\n            </h6>\n            <p class=\"mbr-text mbr-fonts-style mb-3\" mbr-if=\"showText\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text, .mbr-section-btn\">\n              Lorem ipsum dolor sit amet, consectetur adipiscing. Suspendisse faucibus odio vestibulum euismod dapibus.\n            </p>\n            <div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\"><a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Read More</a></div>\n          </div>\n        </div>\n      </div>\n      <div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n        <div class=\"item-wrapper\">\n          <h5 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\">NOVEMBER 12, 2025</h5>\n          <div class=\"item-img mb-3\">\n            <img src=\"../_images/features/features1.jpg\" alt=\"Mobirise Website Builder\" title>\n          </div>\n          <div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n\n            <h6 class=\"item-subtitle mbr-fonts-style pt-2 mb-3\" mbr-theme-style=\"display-5\" data-app-selector=\".item-subtitle\" mbr-if=\"showCardSubtitle\">Curabitur egestas augue ipsum, et tempor ex\n              lacinia nec.</h6>\n            <p class=\"mbr-text mbr-fonts-style mb-3\" mbr-if=\"showText\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text, .mbr-section-btn\">\n              Lorem ipsum dolor sit amet, consectetur adipiscing. Suspendisse faucibus odio vestibulum euismod dapibus.\n            </p>\n            <div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\"><a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Read More</a></div>\n          </div>\n        </div>\n      </div>\n      <div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n        <div class=\"item-wrapper\">\n          <h5 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\">DECEMBER 24, 2025</h5>\n          <div class=\"item-img mb-3\">\n            <img src=\"../_images/features/features2.jpg\" alt=\"Mobirise Website Builder\" title>\n          </div>\n          <div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n\n            <h6 class=\"item-subtitle mbr-fonts-style pt-2 mb-3\" mbr-theme-style=\"display-5\" data-app-selector=\".item-subtitle\" mbr-if=\"showCardSubtitle\">Sed tincidunt tempor neque sed maximus\n              tincidunt enim.</h6>\n            <p class=\"mbr-text mbr-fonts-style mb-3\" mbr-if=\"showText\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text, .mbr-section-btn\">\n              Lorem ipsum dolor sit amet, consectetur adipiscing. Suspendisse faucibus odio vestibulum euismod dapibus.\n            </p>\n            <div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\"><a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Read More</a></div>\n          </div>\n        </div>\n      </div>\n\n\n\n    </div>\n  </div>\n</section>",
          "_cid": "u4gooh6zCY",
          "_anchor": "features7-9m",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0 32px",
                "@media (max-width: 992px)": {
                  "padding": "0 24px"
                }
              }
            },
            "@media (max-width: 992px)": {
              ".container": {
                "@media (max-width: 992px)": {
                  "padding": "0 24px"
                }
              }
            },
            ".row": {
              "@media (min-width: 992px)": {
                "margin": "0"
              },
              ".card": {
                "padding": "0",
                "border-radius": "0 !important",
                "@media (max-width: 992px)": {
                  "padding": "0 16px"
                }
              }
            },
            ".title-wrapper": {
              ".mbr-section-title": {
                "padding": "0 32px 32px",
                "margin-bottom": "0",
                "@media (max-width: 992px)": {
                  "padding": "0 24px 24px"
                }
              }
            },
            ".content-wrapper": {
              "padding": "32px",
              "position": "sticky",
              "top": "0",
              "border-top": "1px solid @border",
              "@media (max-width: 992px)": {
                "padding": "24px",
                "border-top": "none"
              },
              ".mbr-section-subtitle": {
                "margin-bottom": "8px",
                "@media (max-width: 992px)": {
                  "text-align": "left"
                }
              },
              ".mbr-text": {
                "margin-bottom": "0",
                "@media (max-width: 992px)": {
                  "text-align": "left"
                }
              }
            },
            ".items": {
              "border-left": "1px solid @border",
              "border-top": "1px solid @border",
              "& when (@reverseContent)": {
                "border-left": "none",
                "border-right": "1px solid @border"
              },
              "@media (max-width: 992px)": {
                "border-top": "1px solid @border"
              },
              ".item": {
                "padding": "32px",
                "border-bottom": "1px solid @border",
                "@media (max-width: 992px)": {
                  "padding": "24px"
                },
                "&:last-child": {
                  "border": "none"
                },
                ".item-wrapper": {
                  ".card-box": {
                    ".card-title": {
                      "margin-bottom": "8px"
                    },
                    ".card-text": {
                      "margin-bottom": "0"
                    }
                  }
                }
              }
            },
            ".image-wrapper": {
              "padding": "32px",
              "border-top": "1px solid @border",
              "@media (max-width: 992px)": {
                "padding": "24px",
                "border-top": "none"
              },
              "img": {
                "height": "350px",
                "object-fit": "cover"
              }
            },
            ".mbr-section-title": {
              "color": "#F9F6E0"
            },
            ".mbr-section-subtitle": {
              "color": "#F9F6E0",
              "text-align": "right"
            },
            ".mbr-text": {
              "color": "#F9F6E0",
              "text-align": "right"
            },
            ".card-title": {
              "color": "#F9F6E0"
            },
            ".card-text": {
              "color": "#F9F6E0"
            }
          },
          "_name": "features09",
          "_sourceTheme": "fabm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features09 fabm5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline=\"\" title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline=\"\" title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked=\"\">\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked=\"\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked=\"\">\n        <input type=\"checkbox\" title=\"Image\" name=\"showImage\" checked=\"\">\n        <input type=\"color\" title=\"Border Color\" value=\"#72716b\" name=\"border\">\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Card Title\" name=\"showCardTitle\" checked=\"\">\n        <input type=\"checkbox\" title=\"Card Text\" name=\"showCardText\" checked=\"\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax=\"\">\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\" selected=\"\" parallax=\"\">\n            <input type=\"color\" title=\"Color\" value=\"#474A48\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n        <input type=\"range\" inline=\"\" title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay &amp;&amp; bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 card\">\n                <div class=\"title-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                        <b>Benefits</b>\n                    </h2>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 card\">\n                <div class=\"content-wrapper\">\n                    <h3 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\" mbr-if=\"showSubtitle\">\n                        <b>Wide Range of Benefits</b>\n                    </h3>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                        Construction companies bring years of experience and expertise to the table. Their teams include\n                        architects, engineers, project managers, and skilled laborers who have the knowledge and\n                        know-how to execute complex projects efficiently.\n                    </p>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 card\">\n                <div class=\"items\">\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                    <b>Quality Workmanship</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    They use high-quality materials, adhere to industry best practices, and employ skilled\n                                    craftsmen to ensure that every aspect of the project is built to last.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                    <b>Cost Efficiency</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    They have established relationships with suppliers, can\n                                    negotiate better prices for materials, and efficiently manage resources to minimize\n                                    waste and cost overruns.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                    <b>Timely Completion</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    They work diligently to ensure that projects are completed on time, helping clients avoid\n                                    costly delays.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                    <b>Safety and Compliance</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    They follow strict safety\n                                    protocols, provide proper training to their employees, and ensure that all work\n                                    complies with local building codes and regulations.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                    <b>Risk Mitigation</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Construction companies are skilled at\n                                    identifying potential risks and developing mitigation strategies to minimize them.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                    <b>Access to Resources</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Construction companies have access to a vast network of suppliers, subcontractors,\n                                    and specialized equipment.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 card\">\n                <div class=\"image-wrapper\" mbr-if=\"showImage\">\n                    <img src=\"../_images/fab/image4.jpg\" alt=\"Mobirise\">\n                </div>\n            </div>\n        </div>\n    </div>\n</section>\n",
          "_cid": "u442xv1Zto",
          "_anchor": "features09-9j",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0 32px",
                "@media (max-width: 992px)": {
                  "padding": "0 24px"
                }
              }
            },
            "@media (max-width: 992px)": {
              ".container": {
                "@media (max-width: 992px)": {
                  "padding": "0 24px"
                }
              }
            },
            ".row": {
              "@media (min-width: 992px)": {
                "margin": "0"
              },
              ".card": {
                "padding": "0",
                "border-radius": "0 !important",
                "&:nth-child(2)": {
                  "border-left": "1px solid @border",
                  "& when (@reverseContent)": {
                    "border-left": "none",
                    "border-right": "1px solid @border"
                  },
                  "@media (max-width: 992px)": {
                    "margin-bottom": "64px"
                  }
                },
                "&:nth-child(3)": {
                  "border-top": "1px solid @border"
                },
                "&:nth-child(4)": {
                  "border-top": "1px solid @border",
                  "border-left": "1px solid @border",
                  "& when (@reverseContent)": {
                    "border-left": "none",
                    "border-right": "1px solid @border"
                  }
                },
                "@media (max-width: 992px)": {
                  "padding": "0 16px",
                  "border": "none !important"
                }
              }
            },
            ".subtitle-wrap": {
              "height": "100%",
              "display": "flex",
              "justify-content": "flex-end",
              "& when (@reverseContent)": {
                "justify-content": "flex-start"
              },
              "@media (max-width: 992px)": {
                "display": "block"
              },
              ".mbr-section-subtitle": {
                "padding": "32px",
                "writing-mode": "tb",
                "transform": "rotate(180deg)",
                "margin": "0",
                "@media (max-width: 992px)": {
                  "transform": "rotate(0)",
                  "writing-mode": "horizontal-tb",
                  "padding": "24px",
                  "border-left": "1px solid @border",
                  "text-align": "left"
                }
              }
            },
            ".content-wrapper": {
              "padding": "32px",
              "@media (max-width: 992px)": {
                "padding": "24px",
                "border-top": "1px solid @border",
                "border-left": "1px solid @border"
              },
              ".mbr-section-title": {
                "margin-bottom": "16px"
              },
              ".mbr-text": {
                "margin-bottom": "0",
                "@media (max-width: 992px)": {
                  "text-align": "left"
                }
              },
              ".mbr-section-btn": {
                "margin-top": "32px",
                "@media (max-width: 992px)": {
                  "text-align": "left",
                  "margin-top": "24px"
                }
              },
              ".list": {
                "margin-top": "32px",
                "@media (max-width: 992px)": {
                  "margin-top": "24px"
                },
                ".item": {
                  "margin-bottom": "24px",
                  ".item-wrapper": {
                    ".card-box": {
                      ".title-wrapper": {
                        "display": "inline-flex",
                        "align-items": "center",
                        ".card-number": {
                          "margin": "0 24px 0 0",
                          "color": "transparent",
                          "-webkit-text-stroke": "1px @number",
                          "-webkit-background-clip": "text"
                        },
                        ".card-title": {
                          "margin-bottom": "0"
                        }
                      }
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#F9F6E0"
            },
            ".mbr-section-subtitle": {
              "color": "#E0B548",
              "text-align": "center"
            },
            ".mbr-text": {
              "color": "#F9F6E0"
            },
            ".card-text": {
              "color": "#F9F6E0"
            }

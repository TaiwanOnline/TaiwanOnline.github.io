          "_name": "article02",
          "_sourceTheme": "fabm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article02 fabm5\" group=\"Article\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"List\" name=\"showList\" checked>\n        <input type=\"checkbox\" title=\"Number\" name=\"showNumber\" condition=\"showList\" checked>\n        <input type=\"color\" title=\"Number Color\" value=\"#E0B548\" name=\"number\" condition=\"showList\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"color\" title=\"Border Color\" value=\"#72716b\" name=\"border\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\" selected parallax>\n            <input type=\"color\" title=\"Color\" value=\"#474A48\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-4 card\">\n                <div class=\"subtitle-wrap\">\n                    <h3 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\" mbr-if=\"showSubtitle\">\n                        <b>Turning Dreams Into Reality</b>\n                    </h3>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-8 card\">\n                <div class=\"content-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                        <b>Exceptional Results</b>\n                    </h2>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                        We are your trusted partner in building projects that inspire and endure.\n                    </p>\n                    <div class=\"list\" mbr-if=\"showList\">\n                        <div class=\"item features-without-image item-mb\">\n                            <div class=\"item-wrapper\">\n                                <div class=\"card-box\">\n                                    <div class=\"title-wrapper\">\n                                        <p class=\"card-number mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showNumber\" data-app-selector=\".card-number, .card-box\">\n                                            <b>1</b>\n                                        </p>\n                                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .card-box\">\n                                            We are dedicated to creating spaces that reflect our clients' vision.\n                                        </p>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"item features-without-image item-mb\">\n                            <div class=\"item-wrapper\">\n                                <div class=\"card-box\">\n                                    <div class=\"title-wrapper\">\n                                        <p class=\"card-number mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showNumber\" data-app-selector=\".card-number, .card-box\">\n                                            <b>2</b>\n                                        </p>\n                                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .card-box\">\n                                            We exceed expectations in quality, innovation and sustainability.\n                                        </p>\n                                    </div>\n                                </div>\n                            </div>\n                        </div><div class=\"item features-without-image item-mb\">\n                            <div class=\"item-wrapper\">\n                                <div class=\"card-box\">\n                                    <div class=\"title-wrapper\">\n                                        <p class=\"card-number mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showNumber\" data-app-selector=\".card-number, .card-box\"><b>3</b></p>\n                                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".card-text, .card-box\">\n                                            We exceed expectations in quality, innovation and sustainability.\n                                        </p>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 card\">\n                <div class=\"subtitle-wrap\">\n                    <h3 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\" mbr-if=\"showSubtitle\">\n                        <b>Quality is a Commitment</b>\n                    </h3>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-8 card\">\n                <div class=\"content-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                        <b>Our Core Values</b>\n                    </h2>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                        Our skilled craftsmen and experienced professionals ensure that every detail is meticulously\n                        crafted to perfection. From the foundation to the finishing touches, our dedication to quality\n                        is evident in every aspect of our work. We understand that every project is unique. Our team of\n                        architects, engineers, and designers collaborates closely with clients to bring their ideas to\n                        life. We combine creativity with practicality, delivering innovative design solutions that\n                        harmonize aesthetics with functionality. <br> <br>\n                        Open and honest communication is at the heart of our business. We keep our clients informed at\n                        every stage of the construction process, providing regular updates and addressing any concerns\n                        promptly.\n                    </p>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                        <a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                            <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                            OUR WORKS\n                        </a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "u442zb6Y2a",
          "_anchor": "article02-9k",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)",
              "& when (@overlay)": {
                ".mbr-overlay": {
                  "background": "@overlayColor",
                  "opacity": "@overlayOpacity"
                }
              }
            },
            ".mbr-section-number": {
              "border": "1px solid currentColor",
              "border-radius": "2rem",
              "padding": "2rem 2rem",
              "color": "#ffffff",
              "width": "fit-content",
              "display": "inline-block"
            },
            ".item:focus, span:focus": {
              "outline": "none"
            },
            ".align-right": {
              "@media (max-width: 767px)": {
                "text-align": "center"
              }
            },
            ".card-wrapper": {
              "background": "@cardsBg2",
              "padding": "4rem 3rem",
              "padding-bottom": "2rem",
              "margin": "0",
              "@media (max-width: 767px)": {
                "padding": "1rem 0rem"
              }
            },
            ".item": {
              "margin-bottom": "2rem"
            },
            "@media (max-width: 767px)": {
              ".item": {
                "margin-bottom": "1rem"
              }
            },
            ".mbr-card-title": {
              "background": "@number",
              "width": "fit-content",
              "border-radius": "1rem",
              "padding": "6px 10px"
            },
            ".item-content": {
              "margin-top": "2rem",
              "padding": "0 2rem 2rem",
              "@media (min-width: 992px) and (max-width: 1200px)": {
                "padding": "2rem 1.5rem",
                "padding-top": "1rem",
                "margin-top": "1rem"
              },
              "@media (max-width: 767px)": {
                "padding": "1rem 1rem",
                "padding-top": "0rem",
                "margin-top": "1rem"
              },
              "display": "flex",
              "flex-direction": "column",
              "height": "100%"
            },
            ".item-wrapper": {
              "position": "relative",
              "background": "@cardsBg",
              "height": "100%",
              "display": "flex",
              "flex-flow": "column nowrap",
              ".item-footer": {
                "margin-top": "auto"
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff",
              "text-align": "left"
            },
            ".mbr-text, .item .mbr-section-btn": {
              "text-align": "center"
            },
            ".mbr-number": {
              "color": "#f0466a"
            },
            ".mbr-section-subtitle, .mbr-section-head .mbr-section-btn": {
              "text-align": "left",
              "color": "#ffffff"
            },
            ".mbr-text": {
              "text-align": "left"
            },
            ".mbr-text, .mbr-card-btn": {
              "text-align": "left"
            },
            ".mbr-text, .mbr-section-btn": {
              "text-align": "left"
            },
            ".mbr-text, .item-footer .mbr-section-btn": {
              "text-align": "left"
            },
            ".card-text, .item .mbr-section-btn": {
              "text-align": "left",
              "color": "#ffffff"
            },
            ".card-title": {
              "text-align": "left",
              "color": "#ffffff"
            }
          },
          "_name": "features6",
          "_sourceTheme": "tutorm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"tutorm5 features6\" group=\"Features\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n  <mbr-parameters>\n    <header>Size</header>\n    <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n    <input type=\"range\" inline=\"\" title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n    <input type=\"range\" inline=\"\" title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n    <select title=\"Columns\" name=\"cardsWidth\">\n      <option value=\"12\">1</option>\n      <option value=\"6\">2</option>\n      <option value=\"4\">3</option>\n      <option value=\"3\" selected=\"\">4</option>\n    </select>\n    <header>Show/Hide</header>\n    <input type=\"checkbox\" name=\"showTitle\" title=\"Title\" checked=\"\">\n    <input type=\"checkbox\" name=\"showSubtitle\" title=\"Subtitle\">\n    <input type=\"checkbox\" name=\"showMainButtons\" title=\"Buttons\">\n    <input type=\"checkbox\" name=\"showMainNumber\" title=\"Number\" checked=\"\">\n    <header>Cards</header>\n    <input type=\"checkbox\" name=\"showCardTitle\" title=\"Title\">\n    <input type=\"color\" name=\"number\" title=\"Color\" value=\"#fed9e1\" condition=\"showCardTitle\">\n    <input type=\"checkbox\" name=\"showCardSubtitle\" title=\"Subtitle\">\n    <input type=\"color\" name=\"cardsBg2\" title=\"Card 1\" value=\"#232323\">\n    <input type=\"color\" name=\"cardsBg\" title=\"Card 2\" value=\"#3b3a3a\">\n    <header>Background</header>\n    <fieldset type=\"background\" parallax=\"\" name=\"bg\" required=\"\">\n      <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n      <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected=\"\">\n    </fieldset>\n    <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked=\"\">\n    <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay &amp;&amp; bg.type == 'image'\">\n    <input type=\"range\" inline=\"\" title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay &amp;&amp; bg.type == 'image'\">\n  </mbr-parameters>\n  <div class=\"mbr-overlay\" mbr-if=\"overlay &amp;&amp; bg.type !== 'color'\"></div>\n  <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n\n    <div class=\"row card-wrapper\">\n      <div class=\"col-12  col-lg-10 content-head\">\n        <div class=\"mbr-section-head mb-5\" mbr-if=\"showTitle || showSubtitle\">\n          <h4 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">Assessment and evaluation are integral <a href=\"#\" class=\"text-primary\">components</a> of any training program.</h4>\n          <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-4\" mbr-theme-style=\"display-7\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle, .mbr-section-head .mbr-section-btn\">\n            Lorem ipsum dolor sit amet, consectetur adipiscing elit.\n          </h5>\n          <div class=\"mbr-section-btn align-center item-footer mb-0 mt-4\" mbr-if=\"showMainButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons=\"\" mbr-theme-style=\"display-7\">\n            <a href=\"\" class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Get Started</a>\n          </div>\n        </div>\n      </div>\n      <div class=\"col-lg-2 mb-5 align-right\" mbr-if=\"showMainNumber\">\n\n        <h4 class=\"mbr-section-number mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".mbr-section-number\">№1</h4>\n\n\n      </div>\n\n\n\n      <div class=\"item features-without-image col-12 col-md-6 col-lg-{{cardsWidth}} active\">\n        <div class=\"item-wrapper\">\n          <div class=\"item-content\">\n            <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3 mbr-number\" mbr-if=\"showCardTitle\" data-app-selector=\".mbr-number\" mbr-theme-style=\"display-5\">\n              +01</h5>\n            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardSubtitle\" data-app-selector=\".card-title\">\n              <b>Title</b>\n            </h4>\n            <p class=\"card-text mbr-fonts-style mt-0 \" data-app-selector=\".card-text, .item .mbr-section-btn\" mbr-theme-style=\"display-4\">\n              This can be done through quizzes, exams, practical assessments, or other means, depending on the program's\n              goals. </p>\n\n          </div>\n\n        </div>\n      </div>\n      \n      <div class=\"item features-without-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n        <div class=\"item-wrapper\">\n          <div class=\"item-content\">\n            <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3 mbr-number\" mbr-if=\"showCardTitle\" data-app-selector=\".mbr-number\" mbr-theme-style=\"display-5\">\n              +03</h5>\n            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardSubtitle\" data-app-selector=\".card-title\">\n              <b>Title</b>\n            </h4>\n            <p class=\"card-text mbr-fonts-style mt-0 \" data-app-selector=\".card-text, .item .mbr-section-btn\" mbr-theme-style=\"display-4\">\n              Ultimately, a well-executed training program has the power to empower individuals.</p>\n\n          </div>\n        </div>\n      </div><div class=\"item features-without-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n        <div class=\"item-wrapper\">\n          <div class=\"item-content\">\n            <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3 mbr-number\" mbr-if=\"showCardTitle\" data-app-selector=\".mbr-number\" mbr-theme-style=\"display-5\">\n              +03</h5>\n            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardSubtitle\" data-app-selector=\".card-title\">\n              <b>Title</b>\n            </h4>\n            <p class=\"card-text mbr-fonts-style mt-0 \" data-app-selector=\".card-text, .item .mbr-section-btn\" mbr-theme-style=\"display-4\">\n              Ultimately, a well-executed training program has the power to empower individuals.</p>\n\n          </div>\n        </div>\n      </div><div class=\"item features-without-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n        <div class=\"item-wrapper\">\n          <div class=\"item-content\">\n            <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3 mbr-number\" mbr-if=\"showCardTitle\" data-app-selector=\".mbr-number\" mbr-theme-style=\"display-5\">\n              +03</h5>\n            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardSubtitle\" data-app-selector=\".card-title\">\n              <b>Title</b>\n            </h4>\n            <p class=\"card-text mbr-fonts-style mt-0 \" data-app-selector=\".card-text, .item .mbr-section-btn\" mbr-theme-style=\"display-4\">\n              Ultimately, a well-executed training program has the power to empower individuals.</p>\n\n          </div>\n        </div>\n      </div>\n      <div class=\"item features-without-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n        <div class=\"item-wrapper\">\n          <div class=\"item-content\">\n            <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3 mbr-number\" mbr-if=\"showCardTitle\" data-app-selector=\".mbr-number\" mbr-theme-style=\"display-5\">\n              +04</h5>\n            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardSubtitle\" data-app-selector=\".card-title\">\n              <b>Title</b>\n            </h4>\n            <p class=\"card-text mbr-fonts-style mt-0 \" data-app-selector=\".card-text, .item .mbr-section-btn\" mbr-theme-style=\"display-4\">\n              Whether it's preparing employees for new job responsibilities, equipping students with essential skills.\n            </p>\n\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n</section>",
          "_cid": "u4456N9ybR",
          "_anchor": "features6-9l",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        }
      ]
    },
    "page1.html": {
      "settings": {
        "title": "FabM5",
        "order": "2"
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0 32px",
                "@media (max-width: 992px)": {
                  "padding": "0 24px"
                }
              }
            },
            "@media (max-width: 992px)": {
              ".container": {
                "@media (max-width: 992px)": {
                  "padding": "0 24px"
                }
              }
            },
            ".row": {
              "@media (min-width: 992px)": {
                "margin": "0"
              },
              ".card": {
                "padding": "0",
                "border-radius": "0 !important",
                "@media (max-width: 992px)": {
                  "padding": "0 16px"
                }
              }
            },
            ".title-wrapper": {
              ".mbr-section-title": {
                "padding": "0 32px 32px",
                "margin-bottom": "0",
                "@media (max-width: 992px)": {
                  "padding": "0 24px 24px"
                }
              }
            },
            ".content-wrapper": {
              "padding": "32px",
              "position": "sticky",
              "top": "0",
              "border-top": "1px solid @border",
              "@media (max-width: 992px)": {
                "padding": "24px",
                "border-top": "none"
              },
              ".mbr-section-subtitle": {
                "margin-bottom": "8px",
                "@media (max-width: 992px)": {
                  "text-align": "left"
                }
              },
              ".mbr-text": {
                "margin-bottom": "0",
                "@media (max-width: 992px)": {
                  "text-align": "left"
                }
              }
            },
            ".items": {
              "border-left": "1px solid @border",
              "border-top": "1px solid @border",
              "& when (@reverseContent)": {
                "border-left": "none",
                "border-right": "1px solid @border"
              },
              "@media (max-width: 992px)": {
                "border-top": "1px solid @border"
              },
              ".item": {
                "padding": "32px",
                "border-bottom": "1px solid @border",
                "@media (max-width: 992px)": {
                  "padding": "24px"
                },
                "&:last-child": {
                  "border": "none"
                },
                ".item-wrapper": {
                  ".card-box": {
                    ".card-title": {
                      "margin-bottom": "8px"
                    },
                    ".card-text": {
                      "margin-bottom": "0"
                    }
                  }
                }
              }
            },
            ".image-wrapper": {
              "padding": "32px",
              "border-top": "1px solid @border",
              "@media (max-width: 992px)": {
                "padding": "24px",
                "border-top": "none"
              },
              "img": {
                "height": "350px",
                "object-fit": "cover"
              }
            },
            ".mbr-section-title": {
              "color": "#F9F6E0"
            },
            ".mbr-section-subtitle": {
              "color": "#F9F6E0",
              "text-align": "right"
            },
            ".mbr-text": {
              "color": "#F9F6E0",
              "text-align": "right"
            },
            ".card-title": {
              "color": "#F9F6E0"
            },
            ".card-text": {
              "color": "#F9F6E0"
            }
          },
          "_name": "features09",
          "_sourceTheme": "fabm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features09 fabm5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline=\"\" title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline=\"\" title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked=\"\">\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked=\"\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked=\"\">\n        <input type=\"checkbox\" title=\"Image\" name=\"showImage\" checked=\"\">\n        <input type=\"color\" title=\"Border Color\" value=\"#72716b\" name=\"border\">\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Card Title\" name=\"showCardTitle\" checked=\"\">\n        <input type=\"checkbox\" title=\"Card Text\" name=\"showCardText\" checked=\"\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax=\"\">\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\" selected=\"\" parallax=\"\">\n            <input type=\"color\" title=\"Color\" value=\"#474A48\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n        <input type=\"range\" inline=\"\" title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay &amp;&amp; bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 card\">\n                <div class=\"title-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                        <b>Benefits</b>\n                    </h2>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 card\">\n                <div class=\"content-wrapper\">\n                    <h3 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\" mbr-if=\"showSubtitle\">\n                        <b>Wide Range of Benefits</b>\n                    </h3>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                        Construction companies bring years of experience and expertise to the table. Their teams include\n                        architects, engineers, project managers, and skilled laborers who have the knowledge and\n                        know-how to execute complex projects efficiently.\n                    </p>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 card\">\n                <div class=\"items\">\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                    <b>Quality Workmanship</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    They use high-quality materials, adhere to industry best practices, and employ skilled\n                                    craftsmen to ensure that every aspect of the project is built to last.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                    <b>Cost Efficiency</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    They have established relationships with suppliers, can\n                                    negotiate better prices for materials, and efficiently manage resources to minimize\n                                    waste and cost overruns.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                    <b>Timely Completion</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    They work diligently to ensure that projects are completed on time, helping clients avoid\n                                    costly delays.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                    <b>Safety and Compliance</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    They follow strict safety\n                                    protocols, provide proper training to their employees, and ensure that all work\n                                    complies with local building codes and regulations.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                    <b>Risk Mitigation</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Construction companies are skilled at\n                                    identifying potential risks and developing mitigation strategies to minimize them.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                    <b>Access to Resources</b>\n                                </h4>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Construction companies have access to a vast network of suppliers, subcontractors,\n                                    and specialized equipment.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 card\">\n                <div class=\"image-wrapper\" mbr-if=\"showImage\">\n                    <img src=\"../_images/fab/image4.jpg\" alt=\"Mobirise\">\n                </div>\n            </div>\n        </div>\n    </div>\n</section>\n",
          "_cid": "u3CeCBUuXW",
          "_anchor": "features09-4w",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0 32px",
                "@media (max-width: 992px)": {
                  "padding": "0 24px"
                }
              }
            },
            "@media (max-width: 992px)": {
              ".container": {
                "@media (max-width: 992px)": {
                  "padding": "0 24px"
                }
              }
            },
            ".row": {
              "@media (min-width: 992px)": {
                "margin": "0"
              },
              ".card": {
                "border-top": "1px solid @border",
                "padding": "0",
                "border-radius": "0 !important",
                "@media (max-width: 992px)": {
                  "padding": "0 16px",
                  "border": "none"
                }
              }
            },
            ".content-wrapper": {
              "padding": "32px",
              "position": "sticky",
              "top": "0",
              "@media (max-width: 992px)": {
                "padding": "24px"
              },
              ".mbr-section-title": {
                "margin-bottom": "16px",
                "@media (max-width: 992px)": {
                  "text-align": "left"
                }
              },
              ".mbr-text": {
                "margin-bottom": "0",
                "@media (max-width: 992px)": {
                  "text-align": "left"
                }
              },
              ".mbr-section-btn": {
                "margin-top": "32px",
                "@media (max-width: 992px)": {
                  "text-align": "left",
                  "margin-top": "24px"
                }
              }
            },
            ".items": {
              "border-left": "1px solid @border",
              "& when (@reverseContent)": {
                "border-left": "none",
                "border-right": "1px solid @border"
              },
              "@media (max-width: 992px)": {
                "border-top": "1px solid @border"
              },
              ".item": {
                "padding": "32px",
                "border-bottom": "1px solid @border",
                "@media (max-width: 992px)": {
                  "padding": "24px"
                },
                "&:last-child": {
                  "border": "none"
                },
                ".item-wrapper": {
                  ".card-box": {
                    ".title-wrapper": {
                      "margin-bottom": "8px",
                      ".title-wrap": {
                        "display": "inline-flex",
                        ".card-title": {
                          "margin-bottom": "0"
                        },
                        ".card-number": {
                          "margin": "0 0 0 8px",
                          "min-width": "22px"
                        }
                      }
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#F9F6E0"
            },
            ".mbr-text": {
              "color": "#F9F6E0",
              "text-align": "right"
            },
            ".card-title": {
              "color": "#F9F6E0"
            },
            ".card-number": {
              "color": "#E0B548"
            },
            ".card-text": {
              "color": "#F9F6E0"
            },
            ".mbr-section-title, .mbr-section-btn": {
              "text-align": "right"
            }
          },
          "_name": "features01",
          "_sourceTheme": "fabm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features01 fabm5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline=\"\" title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline=\"\" title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked=\"\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked=\"\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked=\"\">\n        <input type=\"color\" title=\"Border Color\" value=\"#72716b\" name=\"border\">\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Card Title\" name=\"showCardTitle\" checked=\"\">\n        <input type=\"checkbox\" title=\"Card Number\" name=\"showNumber\" checked=\"\">\n        <input type=\"checkbox\" title=\"Card Text\" name=\"showCardText\" checked=\"\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax=\"\">\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\" selected=\"\" parallax=\"\">\n            <input type=\"color\" title=\"Color\" value=\"#474A48\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n        <input type=\"range\" inline=\"\" title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay &amp;&amp; bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-4 card\">\n                <div class=\"content-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                        <b>The Services Offered</b>\n                    </h2>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                        We specialize in providing a comprehensive range of logistics services.\n                    </p>\n                    <div mbr-buttons=\"\" mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                        <a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                            <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                            READ MORE\n                        </a>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-8 card\">\n                <div class=\"items\">\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <div class=\"title-wrapper\">\n                                    <div class=\"title-wrap\">\n                                        <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                            <b>Transportation</b>\n                                        </h4>\n                                        <p class=\"card-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\" data-app-selector=\".card-number, .title-wrapper\">\n                                            <b>01</b>\n                                        </p>\n                                    </div>\n                                </div>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Our fleet of modern, well-maintained vehicles is ready to handle a diverse range of\n                                    transportation needs. Whether it's the movement of raw materials, finished products,\n                                    or goods in transit, our transportation services ensure timely and secure deliveries\n                                    to any destination.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <div class=\"title-wrapper\">\n                                    <div class=\"title-wrap\">\n                                        <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                            <b>Warehousing</b>\n                                        </h4>\n                                        <p class=\"card-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\" data-app-selector=\".card-number, .title-wrapper\">\n                                            <b>02</b>\n                                        </p>\n                                    </div>\n                                </div>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Our state-of-the-art warehouses are strategically located to provide efficient\n                                    storage solutions for various types of goods. From temperature-sensitive products to\n                                    bulk commodities, our warehousing services include inventory management, order\n                                    fulfillment, and distribution to end customers.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <div class=\"title-wrapper\">\n                                    <div class=\"title-wrap\">\n                                        <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                            <b>Management</b>\n                                        </h4>\n                                        <p class=\"card-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\" data-app-selector=\".card-number, .title-wrapper\">\n                                            <b>03</b>\n                                        </p>\n                                    </div>\n                                </div>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    We understand the complexities of managing a supply chain and offer end-to-end\n                                    solutions to optimize its performance. Our supply chain management services\n                                    encompass demand forecasting, procurement, production planning, inventory\n                                    optimization, and demand-driven replenishment.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <div class=\"title-wrapper\">\n                                    <div class=\"title-wrap\">\n                                        <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .title-wrapper\">\n                                            <b>Customs Brokerage</b>\n                                        </h4>\n                                        <p class=\"card-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\" data-app-selector=\".card-number, .title-wrapper\">\n                                            <b>04</b>\n                                        </p>\n                                    </div>\n                                </div>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".card-text\">\n                                    Navigating the complexities of customs regulations and compliance can be\n                                    challenging. Our expert customs brokerage team ensures smooth clearance of goods\n                                    across international borders.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>\n",
          "_cid": "u3CeFfo62N",
          "_anchor": "features01-4y",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },

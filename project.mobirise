value=\"@ADDONS_PATH@/leaderm5/components/_images/background1.jpg\" name=\"fallBackImage\"\n               condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\"\n               condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\"\n               condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\"\n         mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div mbr-class=\"{'container': !fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-6\">\n                <div class=\"title-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\"\n                        data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\"\n                        mbr-if=\"showTitle\">\n                        <b>Makes a Good Leader</b>\n                    </h2>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\"\n                       data-app-selector=\".mbr-text\">\n                        Lorem ipsum dolor sit amet, consectetur adipisicing elit. Ad at commodi corporis, deleniti\n                        fugiat illum in inventore iste iusto libero minima quisquam quod rem sed sint? Consequuntur\n                        eaque ipsum perferendis.\n                    </p>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-6\">\n                <div class=\"row cards\">\n                    <div class=\"col-12 col-md-6 card\">\n                        <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\"\n                           data-app-selector=\".mbr-number\">\n                            01\n                        </p>\n                        <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                           data-app-selector=\".mbr-desc\">\n                            <b>Adipisicing elit autem beatae cum deserunt.</b>\n                        </p>\n                    </div>\n                    <div class=\"col-12 col-md-6 card\" mbr-if=\"cards > 1\">\n                        <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\"\n                           data-app-selector=\".mbr-number\">\n                            02\n                        </p>\n                        <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                           data-app-selector=\".mbr-desc\">\n                            <b>Doloremque ducimus facilis illo incidunt ipsa.</b>\n                        </p>\n                    </div>\n                    <div class=\"col-12 col-md-6 card\" mbr-if=\"cards > 2\">\n                        <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\"\n                           data-app-selector=\".mbr-number\">\n                            03\n                        </p>\n                        <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                           data-app-selector=\".mbr-desc\">\n                            <b>Itaque, maiores modi molestias nihil placeat.</b>\n                        </p>\n                    </div>\n                    <div class=\"col-12 col-md-6 card\" mbr-if=\"cards > 3\">\n                        <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\"\n                           data-app-selector=\".mbr-number\">\n                            04\n                        </p>\n                        <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                           data-app-selector=\".mbr-desc\">\n                            <b>Quaerat qui quia repellat repellendus.</b>\n                        </p>\n                    </div>\n                    <div class=\"col-12 col-md-6 card\" mbr-if=\"cards > 4\">\n                        <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\"\n                           data-app-selector=\".mbr-number\">\n                            05\n                        </p>\n                        <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                           data-app-selector=\".mbr-desc\">\n                            <b>Quia repellat repellendus repudiandae.</b>\n                        </p>\n                    </div>\n                    <div class=\"col-12 col-md-6 card\" mbr-if=\"cards > 5\">\n                        <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\"\n                           data-app-selector=\".mbr-number\">\n                            06\n                        </p>\n                        <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                           data-app-selector=\".mbr-desc\">\n                            <b>Lorem ipsum dolor sit amet, consectetur.</b>\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",

        {
          "_name": "content2",
          "_sourceTheme": "leaderm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content2\" group=\"Content\" mbr-class=\"{'mbr-fullscreen': fullScreen,\n                    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\"\n               condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\"\n               condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Circle\" name=\"showCircle\" checked>\n        <input type=\"color\" title=\"Circle Color\" name=\"circle\" value=\"#f3722f\" condition=\"showCircle\" selected>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <select title=\"Cards\" name=\"cards\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\" selected>5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <input type=\"checkbox\" title=\"Number\" name=\"showNumber\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#f1f1f2\" selected>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/leaderm5/components/_images/background1.jpg\" parallax>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/leaderm5/components/_images/background1.jpg\" name=\"fallBackImage\"\n               condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\"\n               condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\"\n               condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\"\n         mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div mbr-class=\"{'container': !fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-6\">\n                <div class=\"image-wrapper\">\n                    <img src=\"@PROJECT_PATH@/assets/images/image1.jpg\" alt=\"Mobirise Website Builder\">\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-6\">\n                <div class=\"text-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\"\n                        data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\"\n                        mbr-if=\"showTitle\">\n                        <b>Leadership Skills</b>\n                    </h2>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\"\n                       data-app-selector=\".mbr-text\">\n                        Lorem ipsum dolor sit amet, consectetur adipisicing elit. Ad at commodi corporis, deleniti\n                        fugiat illum in inventore iste iusto libero minima quisquam quod rem sed sint? Consequuntur\n                        eaque ipsum perferendis.\n                    </p>\n                </div>\n                <div class=\"row cards\">\n                    <div class=\"col-12 col-md-6 card\">\n                        <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\"\n                           data-app-selector=\".mbr-number\">\n                            01\n                        </p>\n                        <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                           data-app-selector=\".mbr-desc\">\n                            <b>Adipisicing elit autem beatae cum deserunt.</b>\n                        </p>\n                    </div>\n                    <div class=\"col-12 col-md-6 card\" mbr-if=\"cards > 1\">\n                        <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\"\n                           data-app-selector=\".mbr-number\">\n                            02\n                        </p>\n                        <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                           data-app-selector=\".mbr-desc\">\n                            <b>Doloremque ducimus facilis illo incidunt ipsa.</b>\n                        </p>\n                    </div>\n                    <div class=\"col-12 col-md-6 card\" mbr-if=\"cards > 2\">\n                        <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\"\n                           data-app-selector=\".mbr-number\">\n                            03\n                        </p>\n                        <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                           data-app-selector=\".mbr-desc\">\n                            <b>Itaque, maiores modi molestias nihil placeat.</b>\n                        </p>\n                    </div>\n                    <div class=\"col-12 col-md-6 card\" mbr-if=\"cards > 3\">\n                        <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\"\n                           data-app-selector=\".mbr-number\">\n                            04\n                        </p>\n                        <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                           data-app-selector=\".mbr-desc\">\n                            <b>Quaerat qui quia repellat repellendus.</b>\n                        </p>\n                    </div>\n                    <div class=\"col-12 col-md-6 card\" mbr-if=\"cards > 4\">\n                        <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\"\n                           data-app-selector=\".mbr-number\">\n                            05\n                        </p>\n                        <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                           data-app-selector=\".mbr-desc\">\n                            <b>Quia repellat repellendus repudiandae.</b>\n                        </p>\n                    </div>\n                    <div class=\"col-12 col-md-6 card\" mbr-if=\"cards > 5\">\n                        <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showNumber\"\n                           data-app-selector=\".mbr-number\">\n                            06\n                        </p>\n                        <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\"\n                           data-app-selector=\".mbr-desc\">\n                            <b>Lorem ipsum dolor sit amet, consectetur.</b>\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".row": {
                "padding": "1rem"
              }
            },
            ".image-wrapper": {
              "padding-left": "150px",
              "position": "relative",
              "@media (max-width: 992px)": {
                "padding": "0",
                "margin-bottom": "40px"
              },
              "& when (@reverseContent)": {
                "display": "flex",
                "justify-content": "flex-end",
                "padding-left": "0",
                "padding-right": "150px",
                "@media (max-width: 992px)": {
                  "display": "block",
                  "padding": "0",
                  "margin-bottom": "40px"
                }
              },
              "& when (@showCircle)": {
                "&::before": {
                  "content": "''",
                  "position": "absolute",
                  "left": "-1rem",
                  "bottom": "-7rem",
                  "display": "block",
                  "width": "300px",
                  "height": "300px",
                  "border": "30px solid @circle",
                  "border-radius": "50%",
                  "background-color": "transparent",
                  "z-index": "5",
                  "& when (@reverseContent)": {
                    "left": "auto",
                    "right": "-1rem"
                  },
                  "@media (max-width: 992px)": {
                    "display": "none"
                  }
                },
                "&::after": {
                  "content": "''",
                  "position": "absolute",
                  "left": "-4.4rem",
                  "bottom": "-10.5rem",
                  "display": "block",
                  "width": "410px",
                  "height": "410px",
                  "border": "30px solid @circle",
                  "border-radius": "50%",
                  "background-color": "transparent",
                  "z-index": "1",
                  "& when (@reverseContent)": {
                    "left": "auto",
                    "right": "-4.4rem"
                  },
                  "@media (max-width: 992px)": {
                    "display": "none"
                  }
                }
              },
              "img": {
                "width": "300px",
                "max-height": "450px",
                "border-radius": "300px 300px 0 0",
                "z-index": "2",
                "position": "relative",
                "@media (max-width: 992px)": {
                  "margin": "0 auto"
                }
              }
            },
            ".text-wrapper": {
              "padding-right": "110px",
              "@media (max-width: 992px)": {
                "padding": "0"
              },
              "& when (@reverseContent)": {
                "padding-right": "0",
                "@media (max-width: 992px)": {
                  "padding": "0"
                }
              },
              ".mbr-section-title": {
                "margin-bottom": "15px"
              },
              ".mbr-text": {
                "margin-bottom": "16px"
              }
            },
            ".cards": {
              ".card": {
                "margin-bottom": "20px",
                ".mbr-number": {
                  "margin": "0"
                },
                ".mbr-desc": {
                  "margin": "0"
                }
              }
            },
            ".mbr-section-title": {
              "color": "#ee2947"
            },
            ".mbr-text": {
              "color": "#1e4381"
            },
            ".mbr-number": {
              "color": "#ee2947"
            },
            ".mbr-desc": {
              "color": "#1e4381"
            }
          },
